WLINE5DO12_flag = {}

--Пользовательская функция, выполняемая каждый цикл в PAC.

function user_eval()
    bertsch:Evaluate()
    alpma:Evaluate()
    pumps:evaluate()
    safety:evaluate()
    local st
    if P4820V1:get_state() == 1 then st = 1 else st = 0 end
    ALPMAGW5DO482011:set_state( st )
    if P4820V2:get_state() == 1 then st = 1 else st = 0 end
    ALPMAGW5DO482012:set_state( st )

    ALPMAGW5AO484011:set_value( P4840TE1:get_value() )
    ALPMAGW5AO487011:set_value( P4870TE1:get_value() )
    ALPMAGW5AO487511:set_value( P4875TE1:get_value() )
    ALPMAGW5AO488511:set_value( P4885TE1:get_value() )
    --lifebit Alpma
    ALPMAGW5DO1:set_state( ALPMAGW5DI1:get_state() )

    THWP1DO479012:set_state( ALPMAGW5DI479012:get_state() )
    ALPMAGW5DO479012:set_state( THWP1DI479012:get_state() )
    --Whey signals
    BERTSCH_MOZ_GW1DO71:set_state( W14DI1:get_state() )
    BERTSCH_MOZ_GW1DO61:set_state( W14DI11:get_state() )
    W14DO11:set_state( BERTSCH_MOZ_GW1DI61:get_state() )
    --Translate counter value
    WLINE10FQT1_VIRT:eval( WLINE10AI12:get_value(), WLINE10AI12:get_value(), 0 )
end
