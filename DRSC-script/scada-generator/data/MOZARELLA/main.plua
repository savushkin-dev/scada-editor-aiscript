function prg.master1:delay_init()
    local PAR = self.PAR_FLOAT
    self.operations =
        {
        FILL_GROUP =
            {
            O7  = 6,
            IN1 = 7,
            BRN4 = 14,
            O7_BERTSCH = 15,
            O8_BERTSCH = 16,
            W_LINE_10 = 21,
            },
        OUT_GROUP =
            {
            OUT1 = 8,
            WR1 = 22,
            },
        }
    self:add_unit_batch( 1, prg.tank_coag1 )
    self:add_unit_batch( 9, prg.f_brine_tank1 )
    self:add_unit_batch( 10, prg.f_brine_tank2 )
    self:add_unit_batch( 17, prg.water_tank1 )

    self.fill_group_info =
        {
        [ self.operations.FILL_GROUP.O7 ] =
            {
            line = prg.line_in_o7,      --Линия, по которой идет наполнение.

            --№ параметров первого и последнего танков очереди.
            FIRST_SOURCE_TANK_PARAM = self.PAR_FLOAT.ENQ_O7_TANK1_ALPMA,
            LAST_SOURCE_TANK_PARAM  = self.PAR_FLOAT.ENQ_O7_TANK5_ALPMA,
            },
        [ self.operations.FILL_GROUP.IN1 ] =
            {
            line = prg.line_in_f_brine_in1,      --Линия, по которой идет наполнение.

            --№ параметров первого и последнего танков очереди.
            FIRST_SOURCE_TANK_PARAM = self.PAR_FLOAT.ENQ_F_BRINE_IN_TANK1,
            LAST_SOURCE_TANK_PARAM  = self.PAR_FLOAT.ENQ_F_BRINE_IN_TANK2,
            },
        [ self.operations.FILL_GROUP.BRN4 ] =
            {
            line = prg.line_in_brn4,      --Линия, по которой идет наполнение.

            --№ параметров первого и последнего танков очереди.
            FIRST_SOURCE_TANK_PARAM = self.PAR_FLOAT.ENQ_BRN4_TANK1,
            LAST_SOURCE_TANK_PARAM  = self.PAR_FLOAT.ENQ_BRN4_TANK4,
            },
        [ self.operations.FILL_GROUP.O7_BERTSCH ] =
            {
            line = prg.line_in_bertsch_o7,      --Линия, по которой идет наполнение.

            --№ параметров первого и последнего танков очереди.
            FIRST_SOURCE_TANK_PARAM = self.PAR_FLOAT.ENQ_O7_TANK1_BERTSCH,
            LAST_SOURCE_TANK_PARAM  = self.PAR_FLOAT.ENQ_O7_TANK5_BERTSCH,
            },
        [ self.operations.FILL_GROUP.O8_BERTSCH ] =
            {
            line = prg.line_in_o8,      --Линия, по которой идет наполнение.

            --№ параметров первого и последнего танков очереди.
            FIRST_SOURCE_TANK_PARAM = self.PAR_FLOAT.ENQ_O8_TANK1,
            LAST_SOURCE_TANK_PARAM  = self.PAR_FLOAT.ENQ_O8_TANK5,
            },
        [ self.operations.FILL_GROUP.W_LINE_10 ] =
            {
            line = prg.line_in_wline10,      --Линия, по которой идет наполнение.

            TANK_FILL = prg.water_tank1.operations.WORK,

            --№ параметров первого и последнего танков очереди.
            FIRST_SOURCE_TANK_PARAM = self.PAR_FLOAT.ENQ_NUMBER1_WLINE10,
            LAST_SOURCE_TANK_PARAM  = self.PAR_FLOAT.ENQ_NUMBER3_WLINE10,
            },
        }
    self.out_group_info =
        {
        [ self.operations.OUT_GROUP.OUT1 ] =
            {
            line    = prg.line_out_f_brine_out1,              --Линия, по которой идет выдача.

            --№ параметра для линии для режима работы;
            --№ параметра, куда пишем новый шаг;
            --№ операции выдачи для линии.
            MANUAL_PAR_N = prg.line_out_f_brine_out1.PAR_FLOAT.OPER_MODE,
            STEP_N       = prg.line_out_f_brine_out1.PAR_FLOAT.OPER_SRC,
            LINE_OUT     = prg.line_out_f_brine_out1.operations.OUT,

            TANK_OUT = prg.f_brine_tank1.operations.OUT,--№ операции выдачи для танка.
            FIRST_DST_TANK_N = 1,               --№ первого танка.
            LAST_DST_TANK_N  = 2,               --№ последнего танка.

            --№ параметров первого и последнего танков очереди.
            FIRST_DST_TANK_PARAM = self.PAR_FLOAT.ENQ_F_BRINE_OUT_TANK1,
            LAST_DST_TANK_PARAM  = self.PAR_FLOAT.ENQ_F_BRINE_OUT_TANK2,
            },
        [ self.operations.OUT_GROUP.WR1 ] =
            {
            line    = prg.line_out_wr1,              --Линия, по которой идет выдача.

            --№ параметра для линии для режима работы;
            --№ параметра, куда пишем новый шаг;
            --№ операции выдачи для линии.
            MANUAL_PAR_N = prg.line_out_wr1.PAR_FLOAT.OPER_MODE,
            STEP_N       = prg.line_out_wr1.PAR_FLOAT.OPER_SRC,
            LINE_OUT     = prg.line_out_wr1.operations.OUT,

            TANK_OUT = prg.water_tank1.operations.WORK,--№ операции выдачи для танка.
            FIRST_DST_TANK_N = 1,               --№ первого танка.
            LAST_DST_TANK_N  = 1,               --№ последнего танка.

            --№ параметров первого и последнего танков очереди.
            FIRST_DST_TANK_PARAM = self.PAR_FLOAT.ENQ_NUMBER1_WR1,
            LAST_DST_TANK_PARAM  = self.PAR_FLOAT.ENQ_NUMBER3_WR1,
            },
        }
end
-- ---------------------------------------------------------------------------
function prg.master1:user_init_operation( m )
    local par = self.par_float
    if m == self.operations.FILL_GROUP.W_LINE_10 then
        local info = self.fill_group_info[ m ]
        if par[ info.FIRST_SOURCE_TANK_PARAM ] == info.line.CMD.IN_LINE then
            local l_oper_mngr = info.line:get_modes_manager()
            local l_oper = l_oper_mngr[ info.line.operations.FILL ]
            l_oper:to_step( info.line.steps.FILL.RUN.IN_LINE )
        end
    end
end
------------------------------------------------------------------------------
--Пользовательская функция инициализации, выполняемая однократно в PAC.

function user_init()
    alpma:Init()
    bertsch:Init()
    prg.master1:delay_init()
    pumps:init( prg.master1 )
    pumps:add_signal(
        { ALPMAGW5AI480512, 'P4805M1' },
        { ALPMAGW5AI482012, 'P4820M1' },
        { ALPMAGW5AI483512, 'P4835M1' },
        { ALPMAGW5AI484012, 'P4840M1' },
        { ALPMAGW5AI485012, 'P4850M1' },
        { ALPMAGW5AI487012, 'P4870M1' },
        { ALPMAGW5AI487512, 'P4875M1' },
        { ALPMAGW5AI488512, 'P4885M1' } )

    safety:init( prg.master1 )
    safety:add_btn(
        { CAB1SB1, 'CAB1SB1' },
        { CAB2SB1, 'CAB2SB1' },
        { CAB3SB1, 'CAB3SB1' },
        { CAB4SB1, 'CAB4SB1' },
        { CAB5SB1, 'CAB5SB1' } )
    safety:add_rly(
        { CAB1DI2, 'CAB1DI2' },
        { CAB2DI2, 'CAB2DI2' },
        { CAB3DI2, 'CAB3DI2' },
        { CAB4DI2, 'CAB4DI2' },
        { CAB5DI2, 'CAB5DI2' } )

    -- Установка начальных значений
    if G_PAC_INFO():is_emulator() == true then
        for i = 1, 1 do
            prg.master1:set_cmd( "CMD", 0, 1001 + i - 1 ) --Пуск партии.
        end
        __LA_TANK1LS1:set_cmd( "ST", 0, 1 )
        __MCA4LINE3DI21:set_cmd( "ST", 0, 1 )
        __WATER_TANK1LS1:set_cmd( "ST", 0, 1 )
        __WATER_TANK1LS2:set_cmd( "ST", 0, 1 )
    end
    WLINE10FQT1_VIRT = virtual_FQT( 'WLINE10FQT1' )
end
