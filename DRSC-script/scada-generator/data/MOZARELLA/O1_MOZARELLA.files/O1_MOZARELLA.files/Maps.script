function extern OnInitProductionBrine(Self);
local tnk, m1, tnkObj, ls1, ls2, te1, te2, te3, lt, gs2, gs3, gs4, gs5, gs6, master, mixobj, heatobj, washobj;
local cmd, kr, nmr, v, objNum, objNumMix, objNmr, objNmrMix, objNmrWash, objNumHeat, objNumWash, objNmrHeat, b, lab;
local mode1, mode2, mode3, mode4, mode5, mode6, mode7, mode8, mode9, mode10, mode11, mode12, mode13, mode14, mode50, mode51, mode60, mode52, mode53, mode54, mode70;
local av1, av2, av3, av4, av5, av6, av7, av8, av9, av10, av11, av12, av13, av14, av50, av51, av60, av52, av53, av54, av70;
local v1, v13;
local masterModeNmr, masterModeNum;
local trend, capt, foot;


trend := self.R('RTrendBR');
trend.ClearTrend;


self.R('RModeTimeBR').ClearJoinList; //операция коагулятора
self.R('RStepTimeBR').ClearJoinList; //время шага
self.R('RStepStrBR').ClearJoinList; //отображение шага


//_______________операции____________________
self.R('RMode1BR').ClearJoinList;  //мойка
self.R('RMode2BR').ClearJoinList;  //наполнение
self.R('RMode3BR').ClearJoinList;  //нагрев                           
self.R('RMode4BR').ClearJoinList;  //выдача



//_______________операции____________________
self.R('RMode1W').ClearJoinList;  //мойка  WASH2

self.R('R_hand_modeBRN').ClearJoinList;//ручноеета

//___________доступность_______________
self.R('RAv1BR').ClearJoinList;  //мойка
self.R('RAv2BR').ClearJoinList;  //наполнение
self.R('RAv3BR').ClearJoinList;  //нагрев
self.R('RAv4BR').ClearJoinList;  //Выдача

//___________доступность_______________
self.R('RAv1W').ClearJoinList;  //мойка WASH2

//_________step____________
self.R('Rstep01BR').ClearJoinList;  //мойка
self.R('Rstep02BR').ClearJoinList;  //наполнение
self.R('Rstep03BR').ClearJoinList;  //нагрев 
self.R('Rstep04BR').ClearJoinList;  //выдача

//_________step____________
self.R('Rstep01W').ClearJoinList;  //мойка WASH2

self.R('RModeTableBR').ClearJoinList;//таблица с параметрами коагулятора

if (prj.TnkNum < 10)
  nmr := str(prj.TnkNum,1);
else
  nmr := str(prj.TnkNum,2);
end;

//debug;

objNum := prj.TnkObjBtnStartBRN;  
objNumWash := prj.TnkObjBtnStartWash; //wash1 - obj38
objNmrWash := str(objNumWash,1);

if (objNum < 10)
  objNmr := str(objNum,1);
else
  objNmr := str(objNum,2);
end;

cmd:='BrineTankObj'+nmr; //коагуляторы
tnkObj:=&&cmd;
prj.Tank := tnkObj;


cmd:='WashObj2';//+nmr; //коагуляторы
washObj:=&&cmd;

//debug;


cmd:='BRINE_TANK'+nmr+'GS1';
kr:=&&cmd;
  
cmd := 'BRINE_TANK'+nmr+'LS1';
ls1 := &&cmd;
  
cmd := 'BRINE_TANK'+nmr+'LS2';
ls2 := &&cmd;
  
cmd := 'BRINE_TANK'+nmr+'TE1';
te1 := &&cmd;
  
cmd := 'BRINE_TANK'+nmr+'LT1';
lt := &&cmd;

cmd := 'Obj'+objNmr+'_M1'; //мойка
mode1 := &&cmd;

cmd := 'Obj'+objNmr+'_AV1'; //мойка
av1 := &&cmd;

cmd := 'Obj'+objNmr+'_M2';  //наполнение
mode2 := &&cmd;

cmd := 'Obj'+objNmr+'_AV2'; //наполнение
av2 := &&cmd;

cmd := 'Obj'+objNmr+'_M3';  //нагрев
mode3 := &&cmd;

cmd := 'Obj'+objNmr+'_AV3'; //нагрев
av3 := &&cmd;

cmd := 'Obj'+objNmr+'_M4';  //выдача
mode4 := &&cmd;

cmd := 'Obj'+objNmr+'_AV4'; //выдача
av4 := &&cmd;


cmd := 'Obj'+objNmrWash+'_M1'; //мойка wash2
mode7 := &&cmd;

cmd := 'Obj'+objNmrWash+'_AV1'; //мойка  wash2
av7 := &&cmd;

cmd := 'MasterObj';
master := &&cmd;

self.R('RMode1BR').ChangeUnit(mode1.name);  //мойка
self.R('RAv1BR').ChangeUnit(av1.name);

self.R('RMode2BR').ChangeUnit(mode2.name);   //наполнение
self.R('RAv2BR').ChangeUnit(av2.name);

self.R('RMode3BR').ChangeUnit(mode3.name);   //нагрев
self.R('RAv3BR').ChangeUnit(av3.name);

self.R('RMode4BR').ChangeUnit(mode4.name);   //выдача
self.R('RAv4BR').ChangeUnit(av4.name);

self.R('RMode1W').ChangeUnit(mode7.name);  //мойка
self.R('RAv1W').ChangeUnit(av7.name);


self.R('RModeTimeBR').JoinToProp(tnkObj.name,'Time_Str'); //время операции коагулятора
self.R('RStepStrBR').JoinToProp(tnkObj.name,'Step_Str');  //шаг операции коагулятора
self.R('RStepTimeBR').JoinToProp(tnkObj.name,'Step_Time_Str'); //время шага операции коагулятора

self.R('R_hand_modeBRN').JoinToProp(tnkObj.name,'S_PAR_F6'); //ручное
//_____________step__________
self.R('Rstep01BR').JoinToProp(tnkObj.name,'step1');
self.R('Rstep02BR').JoinToProp(tnkObj.name,'step2');
self.R('Rstep03BR').JoinToProp(tnkObj.name,'step3');
self.R('Rstep04BR').JoinToProp(tnkObj.name,'step4');

//_____________step__________
self.R('Rstep01W').JoinToProp(washObj.name,'step1');   //wash2


capt:= 'Танк рассола №' + nmr;
foot:= '5-Мойка; 10-Наполнение в 4885; 15-Циркуляция через 4885; 20-Откачка из 4885; ';


trend.JoinToProp( tnkObj.name, 'Ladder');
trend.SetCaption( tnkObj.name, 'Ladder', 'Коагулятор' );
trend.SetStairs( tnkObj.name, 'Ladder', 1, 0, 0);


trend.JoinToProp(te1.name,'V');
trend.SetCaption( te1.name, 'V', 'Темп. т.№' + nmr );
trend.SetStairs( te1.name, 'V', 1, 0, 0 );
  
trend.JoinToProp(lt.name,'Clevel');
trend.SetCaption( lt.name, 'Clevel', 'Масса,кг/10' );
trend.SetStairs( lt.name, 'Clevel', 0.1, 0, 0 ); //для корректного отображения на тренде
   
trend.JoinToProp( LS1.name,'ST');
trend.SetCaption( LS1.name, 'ST', 'НУ,0-Выкл./5-Вкл.' );
trend.SetStairs( LS1.name, 'ST', 5, 0, 0 );
  
trend.JoinToProp( LS2.name,'ST');
trend.SetCaption( LS2.name, 'ST', 'ВУ,100-Выкл./105-Вкл.' );
trend.SetStairs( LS2.name, 'ST', 5, 100, 0 );
  
trend.JoinToProp( kr.name,'ST');
trend.SetCaption( kr.name, 'ST', 'Датчик люка,20-закр./25-откр.' );
trend.SetStairs( kr.name, 'ST', 5, 20, 0 );
  

trend.SetTitle( capt );
trend.SetFooter( foot );

prj.TnkStat:=tnkObj;

prj.SetTableBR( tnkObj );
self.R('RModeTableBR').Visible := true;
endf;

function extern OnInitProductionBRN(Self);
local tnk, m1, tnkObj, ls1, ls2, te1, te2, te3, lt, gs2, gs3, gs4, gs5, gs6, master, mixobj, coolobj;
local cmd, kr, nmr, v, objNum, objNumMix, objNmr, objNmrMix, objNumHeat, objNmrHeat, objNumCoolBRN, objNumMixBRN, objNmrCoolBRN, objNmrMixBRN;
local mode1, mode2, mode3, mode4, mode5, mode6, mode7, mode8, mode9, mode10, mode11, mode12, mode13, mode14, mode50, mode51, mode52, mode53, mode54, mode70;
local av1, av2, av3, av4, av5, av6, av7, av8, av9, av10, av11, av12, av13, av14, av50, av51, av52, av53, av54, av70;
local masterModeNmr, masterModeNum;
local trend, capt, foot;


trend := self.R('RTrendNewBRN');
trend.ClearTrend;

self.R('RCaptBRN').ClearJoinList; //название
self.R('RLS2_1').ClearJoinList;
self.R('RLS1_1').ClearJoinList;
