self.R('RAv2BRN').ClearJoinList;  //наполнение
self.R('RAv3BRN').ClearJoinList;  //нагрев
self.R('RAv4BRN').ClearJoinList;  //Выдача
self.R('RAv5BRN').ClearJoinList;  //Выдача

//_________step____________
self.R('Rstep01BRN').ClearJoinList;  //мойка
