while( i < 5 )
  if ( i < 10)
      par_num := str(i, 1);
  else                   
      par_num := str(i, 2);
  end;                     
  self.R(table2.name).JoinToProp('SYSTEM','SP'+par_num );
  i := i +1;
end;
 self.R(table2.name).JoinToProp('SYSTEM','CYCLETIME' );

{Table := self.R('RParMaster');
