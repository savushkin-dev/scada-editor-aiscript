self.R('RStepMixTimeBRN').ClearJoinList;//время шага перемешивания
self.R('RStepMixStrBRN').ClearJoinList; //отображение шага перемешивания

self.R('R_VInPBRN').ClearJoinList;  //задано
self.R('R_VInPZBRN').ClearJoinList; //набрано

self.R('RPartNBRN').ClearJoinList;//номер партии

self.R('RStart_01_M01BRN').ClearJoinList; //M01
self.R('RStop_03_M01BRN').ClearJoinList;  //M01
self.R('RPause_02_M01BRN').ClearJoinList;//M01

//_______________операции____________________
self.R('RMode1BRN').ClearJoinList;  //мойка
self.R('RMode2BRN').ClearJoinList;  //наполнение
self.R('RMode3BRN').ClearJoinList;  //нагрев                           
