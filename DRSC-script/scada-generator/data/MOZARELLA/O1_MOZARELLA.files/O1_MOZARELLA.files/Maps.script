  end;
  if ((i<>8) and (i<>9) and (i<>10) and (i<>13) and (i<>14) and (i<>15) and (i<>16) and (i<>17) and (i<>18) and (i<>19) and (i<>20) and (i<>23) and (i<>24) and (i<>25) and (i<>26) and (i<>27) and (i<>28) and (i<>29) and (i<>30))                   
