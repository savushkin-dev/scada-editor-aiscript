local cmd, tnk, mix;
local Table1, Table2, Table3, Table4, Table5, Table6;
local trend;
local capt, foot;

//параметры коагуляторов--------------------------------------------
//i := 1;
Table1 := self.R('RParP4870');
Table1.ClearJoinList;

i := 6; //стартовый параметр

while( i < 23 )
if ( i < 10)
  par_num := str(i, 1);
else
  par_num := str(i, 2);
end;
  //if ((i<>7) and (i<>8) and (i<>9) and (i<>10) and (i<>11) and (i<>12) and (i<>13) and (i<>14) and (i<>15) and (i<>16))
   if ((i<>6) and (i<>7) and (i<>8) and (i<>9) and (i<>10) and (i<>11) and (i<>12) and (i<>13) and (i<>14) and (i<>15) and (i<>16)and (i<>18) and (i<>20)) 
self.R(table1.name).JoinToProp('P4870Obj1','S_PAR_F'+par_num );    
  end;

i := i + 1;
end;




trend := self.R('RTrendP4870');
trend.ClearTrend;


capt:= 'P4870';
foot:= '5-Мойка; 10-Производство;';


trend.JoinToProp( P4870Obj1.name, 'Ladder');
trend.SetCaption( P4870Obj1.name, 'Ladder', 'P4870' );
trend.SetStairs( P4870Obj1.name, 'Ladder', 1, 0, 0);


trend.SetTitle( capt );
trend.SetFooter( foot );



local tnkObj;
local nmr, objNum, objNumMix, objNmr ;
local mode1, mode2;
local av1, av2;


self.R('RModeTime_6').ClearJoinList; //операция коагулятора
self.R('RStepTime_6').ClearJoinList; //время шага
self.R('RStepStr_6').ClearJoinList; //отображение шага
self.R('R_hand_mode_6').ClearJoinList;//ручноеета
//_________step____________
self.R('Rstep01_6').ClearJoinList;  //мойка
self.R('Rstep02_6').ClearJoinList;  //наполнение

//_______________операции____________________
self.R('RMode1_6').ClearJoinList;  //мойка
self.R('RMode2_6').ClearJoinList;  //наполнение

//___________доступность_______________
self.R('RAv1_6').ClearJoinList;  //мойка
self.R('RAv2_6').ClearJoinList;  //наполнение

objNum := prj.TnkObjBtnStart4870;//     


if (objNum < 10)
  objNmr := str(objNum,1);
else
  objNmr := str(objNum,2);
end;

//cmd:='P4790Obj'+nmr;
//tnkObj :=&&cmd;

cmd := 'Obj'+objNmr+'_M1'; //мойка
mode1 := &&cmd;

cmd := 'Obj'+objNmr+'_AV1'; //мойка
av1 := &&cmd;

cmd := 'Obj'+objNmr+'_M2';  //наполнение
mode2 := &&cmd;

cmd := 'Obj'+objNmr+'_AV2'; //наполнение
av2 := &&cmd;


self.R('RMode1_6').ChangeUnit(mode1.name);  //мойка
self.R('RAv1_6').ChangeUnit(av1.name);

self.R('RMode2_6').ChangeUnit(mode2.name);   //производство
self.R('RAv2_6').ChangeUnit(av2.name);

self.R('RModeTime_6').JoinToProp(P4870Obj1.name,'Time_Str'); //время операции коагулятора
self.R('RStepStr_6').JoinToProp(P4870Obj1.name,'Step_Str');  //шаг операции коагулятора
self.R('RStepTime_6').JoinToProp(P4870Obj1.name,'Step_Time_Str'); //время шага операции коагулятора
self.R('R_hand_mode_6').JoinToProp(P4870Obj1.name,'S_PAR_F6'); //ручное

//_____________step__________
self.R('Rstep01_6').JoinToProp(P4870Obj1.name,'step1');
self.R('Rstep02_6').JoinToProp(P4870Obj1.name,'step2');


endf;

