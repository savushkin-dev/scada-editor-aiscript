function extern OnInitPid(Self);
local table1, table2;
local trend1, trend2;
local pid1, pid2, pid3, pid4, pid5, pid6, cmd;

trend1 := self.R('RPID1Trend');
trend1.ClearTrend;
Table1 := self.R('RPID1Table');
Table1.ClearJoinList;



self.R('RPID1Capt').ClearJoinList;  //название регулятора

self.R('RPID1Hand').ClearJoinList; //ручное управление
self.R('RPID1In').ClearJoinList;
self.R('RPID1InProg').ClearJoinList;

self.R('RPID1Req').ClearJoinList;
self.R('RPID1ReqProg').ClearJoinList;

self.R('RPID1Out').ClearJoinList;
self.R('RPID1OutProg').ClearJoinList;

if (prj.pid = 1)
  cmd := 'PID10'; 
  pid1 := &&cmd;
   
  self.R('RPID1Capt').SetNewText('Охладитель. Формовочная карусель MC-2000 4840');
  
  trend1.JoinToProp( P4840TE1.name, 'V');
  trend1.SetCaption( P4840TE1.name, 'V', 'P4840TE1, C' ); 
  
  trend1.JoinToProp( pid1.name, 'RT_PAR_F1');
  trend1.SetCaption( pid1.name, 'RT_PAR_F1', 'Задание ПИД' );
  
  trend1.JoinToProp( pid1.name, 'RT_PAR_F2');
  trend1.SetCaption( pid1.name, 'RT_PAR_F2', 'Выход ПИД' );

  
  self.R('RPID1In').JoinToProp( P4840TE1.name, 'V'); //бойлер 3
  self.R('RPID1InProg').JoinToProp( P4840TE1.name, 'V');
  
  self.R('RPID1Req').JoinToProp( pid1.name, 'RT_PAR_F1');
  self.R('RPID1Reqprog').JoinToProp( pid1.name, 'RT_PAR_F1');  
  
  self.R('RPID1Out').JoinToProp( pid1.name, 'RT_PAR_F2');
  self.R('RPID1OutProg').JoinToProp( pid1.name, 'RT_PAR_F2');
   
  self.R(Table1.name).JoinToProp(pid1.name,'RT_PAR_F1');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F1');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F2');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F3');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F4');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F5');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F6');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F7');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F9');
  self.R(Table1.name).JoinToProp(pid1.name,'RT_PAR_F2');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F13');
  self.R(Table1.name).JoinToProp(pid1.name,'S_PAR_F14');

  self.R('RPID1Hand').JoinToProp(pid1.name,'S_PAR_F8');
    
end;


if (prj.pid = 2)
  cmd := 'PID11'; 
  pid2 := &&cmd;
   
  self.R('RPID1Capt').SetNewText('Охладитель. Охлаждающая ванна CV5-2 4870');
  
  trend1.JoinToProp( P4870TE1.name, 'V');
  trend1.SetCaption( P4870TE1.name, 'V', 'P4870TE1, C' ); 
  
  trend1.JoinToProp( pid2.name, 'RT_PAR_F1');
  trend1.SetCaption( pid2.name, 'RT_PAR_F1', 'Задание ПИД' );
  
  trend1.JoinToProp( pid2.name, 'RT_PAR_F2');
  trend1.SetCaption( pid2.name, 'RT_PAR_F2', 'Выход ПИД' );

  
  self.R('RPID1In').JoinToProp( P4870TE1.name, 'V'); //бойлер 3
  self.R('RPID1InProg').JoinToProp( P4870TE1.name, 'V');
  
  self.R('RPID1Req').JoinToProp( pid2.name, 'RT_PAR_F1');
  self.R('RPID1Reqprog').JoinToProp( pid2.name, 'RT_PAR_F1');  
  
  self.R('RPID1Out').JoinToProp( pid2.name, 'RT_PAR_F2');
  self.R('RPID1OutProg').JoinToProp( pid2.name, 'RT_PAR_F2');
  
  
  self.R(Table1.name).JoinToProp(pid2.name,'RT_PAR_F1');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F1');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F2');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F3');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F4');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F5');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F6');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F7');
  self.R(Table1.name).JoinToProp(pid2.name,'S_PAR_F9');
  self.R(Table1.name).JoinToProp(pid2.name,'RT_PAR_F2');
