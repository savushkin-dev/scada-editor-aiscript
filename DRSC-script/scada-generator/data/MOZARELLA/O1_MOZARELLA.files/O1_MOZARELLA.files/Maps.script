function extern OnInitProductionWT(Self);
local tnk, m1, tnkObj, ls1, ls2, te1, te2, te3, lt, gs2, gs3, gs4, gs5, gs6, master, mixobj, heatobj;
local cmd, kr, nmr, v, objNum, objNumMix, objNmr, objNmrMix, objNumHeat, objNmrHeat, b, lab;
local mode1, mode2, mode3, mode4, mode5, mode6, mode7, mode8, mode9, mode10, mode11, mode12, mode13, mode14, mode50, mode51, mode60, mode52, mode53, mode54, mode70;
local av1, av2, av3, av4, av5, av6, av7, av8, av9, av10, av11, av12, av13, av14, av50, av51, av60, av52, av53, av54, av70;
local v1, v13;
local masterModeNmr, masterModeNum;
local trend, capt, foot;

trend := self.R('RTrendWT');
trend.ClearTrend;

self.R('RModeTimeWT').ClearJoinList; //операция коагулятора
self.R('RStepTimeWT').ClearJoinList; //время шага
self.R('RStepStrWT').ClearJoinList; //отображение шага

self.R('RMode1WT').ClearJoinList;  //мойка
self.R('RMode2WT').ClearJoinList;  //наполнение
self.R('RMode3WT').ClearJoinList;  //нагрев                           
self.R('RMode4WT').ClearJoinList;  //выдача
self.R('RMode5WT').ClearJoinList;  //выдача
self.R('R_hand_modeWT').ClearJoinList;//ручноеета

self.R('RAv1WT').ClearJoinList;  //мойка
self.R('RAv2WT').ClearJoinList;  //наполнение
self.R('RAv3WT').ClearJoinList;  //нагрев
self.R('RAv4WT').ClearJoinList;  //Выдача
self.R('RAv5WT').ClearJoinList;  //Выдача

self.R('Rstep01WT').ClearJoinList;  //мойка
self.R('Rstep02WT').ClearJoinList;  //наполнение
self.R('Rstep03WT').ClearJoinList;  //нагрев 
self.R('Rstep04WT').ClearJoinList;  //выдача
self.R('Rstep05WT').ClearJoinList;

self.R('RPartNWT').ClearJoinList;//номер партии

self.R('RStart_01_M01WT').ClearJoinList; //M01
self.R('RStop_03_M01WT').ClearJoinList;  //M01
self.R('RPause_02_M01WT').ClearJoinList;//M01


self.R('RModeTableWT').ClearJoinList;//таблица с параметрами коагулятора

if (prj.TnkNum < 10)
  nmr := str(prj.TnkNum,1);
else
  nmr := str(prj.TnkNum,2);
end;

objNum := 46+prj.TnkNum;

if (objNum < 10)
  objNmr := str(objNum,1);
else
  objNmr := str(objNum,2);
end;

cmd:='TankObjWT'+nmr; //коагуляторы
tnkObj:=&&cmd;
prj.Tank := tnkObj;

cmd:='WATER_TANK'+nmr+'LT1';
lt:=&&cmd;

cmd := 'WATER_TANK'+nmr+'TE1';
te1 := &&cmd; 

cmd := 'WATER_TANK'+nmr+'LS1';
ls1 := &&cmd;
  
cmd := 'WATER_TANK'+nmr+'LS2';
ls2 := &&cmd;
  
cmd := 'Obj51_M1'; //мойка
mode1 := &&cmd;

cmd := 'Obj51_AV1'; //мойка
av1 := &&cmd;

cmd := 'Obj'+objNmr+'_M2';  //наполнение
mode2 := &&cmd;

cmd := 'Obj'+objNmr+'_AV2'; //наполнение
av2 := &&cmd;

cmd := 'Obj'+objNmr+'_M3';  //нагрев
mode3 := &&cmd;

cmd := 'Obj'+objNmr+'_AV3'; //нагрев
av3 := &&cmd;

cmd := 'Obj'+objNmr+'_M4';  //выдача
mode4 := &&cmd;

cmd := 'Obj'+objNmr+'_AV4'; //выдача
av4 := &&cmd;

cmd := 'Obj'+objNmr+'_M5';  
mode5 := &&cmd;

cmd := 'Obj'+objNmr+'_AV5'; 
av5 := &&cmd;

cmd := 'MasterObj';
master := &&cmd;

self.R('RMode1WT').ChangeUnit(mode1.name);  //мойка
self.R('RAv1WT').ChangeUnit(av1.name);

self.R('RMode2WT').ChangeUnit(mode2.name);   //наполнение
self.R('RAv2WT').ChangeUnit(av2.name);

self.R('RMode3WT').ChangeUnit(mode3.name);   //нагрев
self.R('RAv3WT').ChangeUnit(av3.name);

self.R('RMode4WT').ChangeUnit(mode4.name);   //выдача
self.R('RAv4WT').ChangeUnit(av4.name);

self.R('RMode5WT').ChangeUnit(mode5.name);   
self.R('RAv5WT').ChangeUnit(av5.name);

self.R('RModeTimeWT').JoinToProp(tnkObj.name,'Time_Str'); //время операции коагулятора
self.R('RStepStrWT').JoinToProp(tnkObj.name,'Step_Str');  //шаг операции коагулятора
self.R('RStepTimeWT').JoinToProp(tnkObj.name,'Step_Time_Str'); //время шага операции коагулятора

self.R('R_hand_modeWT').JoinToProp(tnkObj.name,'S_PAR_F3'); //ручное
//self.R('R_VInPZ').JoinToProp(tnkObj.name,'S_PAR_F12');//задано
//self.R('R_VInP').JoinToProp(tnkObj.name,'S_PAR_F11');//набрано ???

//_____________step__________
self.R('Rstep01WT').JoinToProp(tnkObj.name,'step1');
self.R('Rstep02WT').JoinToProp(tnkObj.name,'step2');
self.R('Rstep03WT').JoinToProp(tnkObj.name,'step3');
self.R('Rstep04WT').JoinToProp(tnkObj.name,'step4');
self.R('Rstep05WT').JoinToProp(tnkObj.name,'step5');

masterModeNum := prj.TnkNum + 16;
if (masterModeNum < 10)
  masterModeNmr := str(masterModeNum,1);
else
  masterModeNmr := str(masterModeNum,2);
end;

self.R('RStart_01_M01WT').JoinToProp(master.name,'Start'+masterModeNmr);  //M01
self.R('RStop_03_M01WT').JoinToProp(master.name,'Stop'+masterModeNmr);    //M01
self.R('RPause_02_M01WT').JoinToProp(master.name,'Pause'+masterModeNmr);  //M01
self.R('RPartNWT').JoinToProp(tnkObj.name,'S_PAR_F4');     //номер партии в танке

capt:= 'Танк воды №' + nmr;
foot:= '5-Мойка; 10-Наполнение; 15-Хранение; 20-Выдача; 25-Работа; ';


trend.JoinToProp( tnkObj.name, 'Ladder');
trend.SetCaption( tnkObj.name, 'Ladder', 'Операции танка' );
trend.SetStairs( tnkObj.name, 'Ladder', 1, 0, 0);

trend.JoinToProp( lt.name, 'CLEVEL');
trend.SetCaption( lt.name, 'CLEVEL', 'Масса, кг' );
trend.SetStairs( lt.name, 'CLEVEL', 1, 0, 0);

trend.JoinToProp( te1.name, 'V');
trend.SetCaption( te1.name, 'V',  'Темп. TE1 T.№'+nmr );
trend.SetStairs( te1.name, 'V', 1, 0, 0);

trend.JoinToProp( LS1.name,'ST');
trend.SetCaption( LS1.name, 'ST', 'НУ,0-Выкл./5-Вкл.' );
trend.SetStairs( LS1.name, 'ST', 5, 0, 0 );
  
trend.JoinToProp( LS2.name,'ST');
trend.SetCaption( LS2.name, 'ST', 'ВУ,100-Выкл./105-Вкл.' );
trend.SetStairs( LS2.name, 'ST', 5, 100, 0 );

trend.SetTitle( capt );
trend.SetFooter( foot );

prj.TnkStat:=tnkObj;

prj.SetTableWT( tnkObj );
self.R('RModeTableWT').Visible := true;

endf;

