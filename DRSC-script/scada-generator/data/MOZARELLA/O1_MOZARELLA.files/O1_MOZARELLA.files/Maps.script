function extern OnInitPID_NEW(Self);
local table1;
local trend1;
local pid1, cmd, tank, vc, fqtPid, te2, pt, m, lt, fqt;
local name;

trend1 := self.R('RPIDTrend');
trend1.ClearTrend;
Table1 := self.R('RPIDTable');
Table1.ClearJoinList;

self.R('RPIDIn').ClearJoinList;
self.R('RPIDInInd').ClearJoinList;

self.R('RPIDReq').ClearJoinList;
self.R('RPIDReqInd').ClearJoinList;

self.R('RPIDOut').ClearJoinList;
self.R('RPIDOutInd').ClearJoinList;

self.R('R_PID_Hand').ClearJoinList;

self.R('RCaptPid').ClearJoinList;

self.R('R_BTN_L').visible:=0;
self.R('R_BTN_R').visible:=0;

if ((prj.pid = 7) or (prj.pid = 8) or (prj.pid = 9))
  self.R('R_BTN_L').visible:=1;
  self.R('R_BTN_R').visible:=1;
end;

if (prj.pid = 7)
  cmd := 'WR1FC1';
  pid1 := &&cmd;
  cmd := 'WR1FQT1';
  fqtPid := &&cmd;
  name:='ПИД-регулятор расхода на линии WR1';
  
  trend1.JoinToProp( fqtPid.name, 'F' );
  trend1.SetCaption( fqtPid.name, 'F', 'Вход' );
  self.R('RPIDIn').JoinToProp( fqtPid.name, 'F' );
  self.R('RPIDInInd').JoinToProp( fqtPid.name, 'F' );
  
end;

if (prj.pid = 8)
  cmd := 'HEATER1TC1';
  pid1 := &&cmd;
  cmd := 'HEATER1TE1';
  fqtPid := &&cmd;
  name:='ПИД-регулятор температуры HEATER1TC1';
  
  trend1.JoinToProp( fqtPid.name, 'V' );
  trend1.SetCaption( fqtPid.name, 'V', 'Вход' );
  self.R('RPIDIn').JoinToProp( fqtPid.name, 'V' );
  self.R('RPIDInInd').JoinToProp( fqtPid.name, 'V' );
  
end;

if (prj.pid = 9)
  cmd := 'HEATER1TC2';
  pid1 := &&cmd;
  cmd := 'HEATER1TE2';
  fqtPid := &&cmd;
  name:='ПИД-регулятор температуры HEATER1TC2';
  
  trend1.JoinToProp( fqtPid.name, 'V' );
  trend1.SetCaption( fqtPid.name, 'V', 'Вход' );
  self.R('RPIDIn').JoinToProp( fqtPid.name, 'V' );
  self.R('RPIDInInd').JoinToProp( fqtPid.name, 'V' );
  
end;


trend1.JoinToProp( pid1.name, 'AZ' );
trend1.SetCaption( pid1.name, 'AZ', 'Задание' );
trend1.JoinToProp( pid1.name, 'BV' );
trend1.SetCaption( pid1.name, 'BV', 'Выход' );
self.R('RPIDReq').JoinToProp( pid1.name, 'AZ' );
self.R('RPIDReqInd').JoinToProp( pid1.name, 'AZ' );
self.R('RPIDOut').JoinToProp( pid1.name, 'BV' );
self.R('RPIDOutInd').JoinToProp( pid1.name, 'BV' );

self.R('R_PID_Hand').JoinToProp( pid1.name, 'MP_is_manual_mode' );

local Filtr;
Filtr := VarArrayCreate([0, 1], varVariant);
//Filtr :=array(2);
Filtr[0] := 'Nmr';
Filtr[1] := 'NSt';

self.R ('RPIDTable').JoinToUnit( pid1.Name, Filtr );
self.R('RCaptPid').SetNewText(name);
endf;

function extern OnInitProduction(Self);
local tnk, m1, tnkObj, ls1, ls2, te1, te2, te3, lt, gs2, gs3, gs4, gs5, gs6, master, mixobj, heatobj, washobj;
local cmd, kr, nmr, v, objNum, objNumMix, objNumWash, objNmr, objNmrWash, objNmrMix, objNumHeat, objNmrHeat, b, lab;
local mode1, mode2, mode3, mode4, mode5, mode6, mode7, mode8, mode9, mode10, mode11, mode12, mode13, mode14, mode50, mode51, mode52, mode53, mode54, mode70, mode80;
local av1, av2, av3, av4, av5, av6, av7, av8, av9, av10, av11, av12, av13, av14, av50, av51, av52, av53, av54, av70, av80;
local v1, v13;
local masterModeNmr, masterModeNum;
local trend, capt, foot;


trend := self.R('RTrendNew');
trend.ClearTrend;

self.R('RCapt').ClearJoinList; //название


self.R('RModeTime').ClearJoinList; //операция коагулятора
self.R('RStepTime').ClearJoinList; //время шага
self.R('RStepStr').ClearJoinList; //отображение шага
self.R('RProdStr').ClearJoinList; //тип продукта, сорт
self.R('RModeHeatTime').ClearJoinList;//операция узла перемешивания
self.R('RStepHeatTime').ClearJoinList;//время шага перемешивания
self.R('RStepHeatStr').ClearJoinList; //отображение шага перемешивания

self.R('R_VInP').ClearJoinList;  //задано
self.R('R_VInPZ').ClearJoinList; //набрано

self.R('RPartN').ClearJoinList;//номер партии

self.R('RStart_01_M01').ClearJoinList; //M01
self.R('RStop_03_M01').ClearJoinList;  //M01
self.R('RPause_02_M01').ClearJoinList;//M01

//_______________операции____________________
self.R('RMode1').ClearJoinList;  //мойка
self.R('RMode2').ClearJoinList;  //наполнение
self.R('RMode3').ClearJoinList;  //нагрев                           
self.R('RMode4').ClearJoinList;  //выдача

self.R('R_hand_mode').ClearJoinList;//ручноеета


self.R('RModW1').ClearJoinList;  //мойка WASH1

//___________доступность_______________
self.R('RAv1').ClearJoinList;  //мойка
self.R('RAv2').ClearJoinList;  //наполнение
self.R('RAv3').ClearJoinList;  //нагрев
self.R('RAv4').ClearJoinList;  //Выдача

self.R('RAvW1').ClearJoinList;  //мойка  WASH1

//_________step____________
self.R('Rstep01').ClearJoinList;  //мойка
self.R('Rstep02').ClearJoinList;  //наполнение
self.R('Rstep03').ClearJoinList;  //нагрев 
self.R('Rstep04').ClearJoinList;  //выдача

//_________step____________
self.R('RstepW01').ClearJoinList;  //мойка WASH1

//_________stepHeat____________
self.R('RHeatstep01').ClearJoinList;  //нагрев

self.R('RModeTable').ClearJoinList;//таблица с параметрами коагулятора
self.R('RModeHeatTable').ClearJoinList; //таблица с параметрами узла нагрева

if (prj.TnkNum < 10)
  nmr := str(prj.TnkNum,1);
else
  nmr := str(prj.TnkNum,2);
end;

//debug;

objNum := prj.TnkObjBtnStart + prj.TnkNum;    
objNumHeat := prj.HeatObjBtnStart + prj.TnkNum; 
objNmrHeat := str(objNumHeat,1);
objNumWash := prj.WashObjBtnStart; //wash1 - obj37
objNmrWash := str(objNumWash,1);

if (objNum < 10)
  objNmr := str(objNum,1);
else
  objNmr := str(objNum,2);
end;

cmd:='CoagObj'+nmr; //коагуляторы
tnkObj:=&&cmd;
prj.Tank := tnkObj;

cmd:='CoagHeatingObj'+nmr; //узел нагрева
heatObj:=&&cmd;

cmd:='WashObj'+nmr; //wash1
washObj:=&&cmd;

//debug;

cmd := 'Obj'+objNmr+'_M1'; //мойка
mode1 := &&cmd;

cmd := 'Obj'+objNmr+'_AV1'; //мойка
av1 := &&cmd;

cmd := 'Obj'+objNmr+'_M2';  //наполнение
mode2 := &&cmd;

cmd := 'Obj'+objNmr+'_AV2'; //наполнение
av2 := &&cmd;

cmd := 'Obj'+objNmr+'_M3';  //нагрев
mode3 := &&cmd;

cmd := 'Obj'+objNmr+'_AV3'; //нагрев
av3 := &&cmd;

cmd := 'Obj'+objNmr+'_M4';  //выдача
mode4 := &&cmd;

cmd := 'Obj'+objNmr+'_AV4'; //выдача
av4 := &&cmd;


cmd := 'Obj'+objNmrHeat+'_M1'; //нагрев
mode50 := &&cmd;

cmd := 'Obj'+objNmrHeat+'_AV1'; //нагрев
av50 := &&cmd;

cmd := 'Obj'+objNmrWash+'_M1'; //мойка  WASH1
mode80 := &&cmd;

cmd := 'Obj'+objNmrWash+'_AV1'; //мойка    WASH1
av80 := &&cmd;

cmd := 'MasterObj';
master := &&cmd;

self.R('RCapt').SetNewText('Сыроизготовитель №'+nmr);  //название

//self.R('RM1').ChangeUnit(m1.name);
//prj.DrawMesh(m1);

self.R('RMode1').ChangeUnit(mode1.name);  //мойка
self.R('RAv1').ChangeUnit(av1.name);

self.R('RMode2').ChangeUnit(mode2.name);   //наполнение
self.R('RAv2').ChangeUnit(av2.name);

self.R('RMode3').ChangeUnit(mode3.name);   //нагрев
self.R('RAv3').ChangeUnit(av3.name);

self.R('RMode4').ChangeUnit(mode4.name);   //выдача
self.R('RAv4').ChangeUnit(av4.name);


self.R('RMode50').ChangeUnit(mode50.name);   //подогрев
self.R('RAv50').ChangeUnit(av50.name);

self.R('RModW1').ChangeUnit(mode80.name);  //мойка  WASH
self.R('RAvW1').ChangeUnit(av80.name);

self.R('RModeTime').JoinToProp(tnkObj.name,'Time_Str'); //время операции коагулятора
self.R('RStepStr').JoinToProp(tnkObj.name,'Step_Str');  //шаг операции коагулятора
self.R('RStepTime').JoinToProp(tnkObj.name,'Step_Time_Str'); //время шага операции коагулятора
self.R('RProdStr').JoinToProp(tnkObj.name,'Capt_Str'); //тип продукта, сорт


self.R('R_hand_mode').JoinToProp(tnkObj.name,'S_PAR_F6'); //ручное

self.R('RModeHeatTime').JoinToProp(heatObj.name,'Time_Str'); //время операции узла перемешивания
self.R('RStepHeatStr').JoinToProp(heatObj.name,'Step_Str'); //шаг узла перемешивания
self.R('RStepHeatTime').JoinToProp(heatObj.name,'Step_Time_Str');// время шага узла перемешивания

self.R('RPartN').JoinToProp(tnkObj.name,'S_PAR_F7');     //номер партии в танке

self.R('R_VInPZ').JoinToProp(tnkObj.name,'S_PAR_F12');//задано
self.R('R_VInP').JoinToProp(tnkObj.name,'S_PAR_F11');//набрано ???

//_____________step__________
self.R('Rstep01').JoinToProp(tnkObj.name,'step1');
self.R('Rstep02').JoinToProp(tnkObj.name,'step2');
self.R('Rstep03').JoinToProp(tnkObj.name,'step3');
self.R('Rstep04').JoinToProp(tnkObj.name,'step4');

//_____________step__________
self.R('RstepW01').JoinToProp(washObj.name,'step1');

//_____________stepMix__________
self.R('RHeatstep01').JoinToProp(heatObj.name,'step1');


masterModeNum := prj.TnkNum + prj.TnkMasterModesStart-1;
if (masterModeNum < 10)
  masterModeNmr := str(masterModeNum,1);
else
  masterModeNmr := str(masterModeNum,2);
end;

self.R('RStart_01_M01').JoinToProp(master.name,'Start'+masterModeNmr);  //M01
self.R('RStop_03_M01').JoinToProp(master.name,'Stop'+masterModeNmr);    //M01
self.R('RPause_02_M01').JoinToProp(master.name,'Pause'+masterModeNmr);  //M01


capt:= 'Сыроизготовитель №' + nmr;
foot:= '5-Мойка; 10-Наполнение; 15-Нагрев; 20-Выдача; ';


trend.JoinToProp( tnkObj.name, 'Ladder');
trend.SetCaption( tnkObj.name, 'Ladder', 'Коагулятор' );
trend.SetStairs( tnkObj.name, 'Ladder', 1, 0, 0);

trend.JoinToProp(heatObj.name, 'Ladder');
trend.SetCaption( heatObj.name, 'Ladder', 'Нагрев' );
trend.SetStairs( heatObj.name, 'Ladder', 1, 0, 0);

trend.SetTitle( capt );
trend.SetFooter( foot );

prj.TnkStat:=tnkObj;

prj.SetTable( tnkObj );
self.R('RModeTable').Visible := true;
self.R('RModeHeatTable').Visible := true;
endf;

function extern OnDeinitProduction(Self);
local trend;

trend := self.R('RTrendNew');
trend.ClearTrend;endf;

function extern OnInitProduction4790(Self);
local i, j, par_num, tnk_num, table;
local cmd, tnk, mix;
local Table1, Table2, Table3, Table4, Table5, Table6;
local trend;
local capt, foot;


//параметры коагуляторов--------------------------------------------
//i := 1;
Table1 := self.R('RParP4790');
