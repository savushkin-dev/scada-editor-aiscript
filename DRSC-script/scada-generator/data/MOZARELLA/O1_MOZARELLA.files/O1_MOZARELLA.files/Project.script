function extern SetNumericPart(Obj);   //для изменения номера партии на карте сыроизготовителя
  local k, par, spar;
  par := &&(obj.name+'.S_PAR_F7');
  if (par<10)
    spar := str(par,1);
  else
    spar := str(par,2);
  end;
  if (MessageDLG('Номер партии = '+spar+', хотите изменить?')=1)
    k := EditIK('Введите номер партии:', 0,1,1000000,0);
    obj.S_PAR_F7 := k;
  end;
endf;

