function extern TrendF(obj);  //Состояние возвратного клапана V21 (stairs).
  // Должно отображаться так: если клапан находится в состоянии выключенном и приходит сигнал обратной связи (state 0),
  //то на графике должна рисоваться прямая на значении параметра
  //№28 Объекта ПОУ "Температура срабатывания возвратного клапана TE21" (LOW_TEMP_LIMIT_PRODUCTION), в противном случае - нуль.
  if ( obj.Heater1V = 0 )
    obj.F28 := obj.S_PAR_F28*1;
  else
    obj.F28 := 0;
  end;
endf;
