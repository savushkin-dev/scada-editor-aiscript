function extern DrawHLA(HLA);  //HLA
  if (HLA.allocate='C')
    
    if (HLA.M = 1)
      if (HLA.L_GREEN=1)
        HLA.setframes(6,0,2);
        HLA.selframe(1);
      end;
      if (HLA.L_RED=1)
        HLA.setframes(6,0,4);
        HLA.selframe(1);
      end;
      if (HLA.L_YELLOW=1)
        HLA.setframes(6,0,3);
        HLA.selframe(1);
      end;
      if (HLA.L_SIREN=1)
        HLA.setframes(6,0,5);
        HLA.selframe(1);
      end;
      if ((HLA.L_GREEN=0) and (HLA.L_RED=0) and (HLA.L_YELLOW=0) and (HLA.L_SIREN=0))
        HLA.setframes(6,0,1);
      end;
    else
      if (HLA.L_GREEN=1)
        HLA.setframes(0,2);
        HLA.selframe(1);
      end;
      if (HLA.L_RED=1)
        HLA.setframes(0,4);
        HLA.selframe(1);
      end;
      if (HLA.L_YELLOW=1)
        HLA.setframes(0,3);
        HLA.selframe(1);
      end;
      if (HLA.L_SIREN=1)
        HLA.setframes(0,5);
        HLA.selframe(1);
      end;
      if ((HLA.L_GREEN=0) and (HLA.L_RED=0) and (HLA.L_YELLOW=0) and (HLA.L_SIREN=0))
        HLA.setframes(0);
        HLA.selframe(1);
      end;
    end;
  end;
endf;

function extern DrawIOLinkMixValve(obj);
  
  local lstr;
  lstr := '0';
  if (obj.M=1)
    lstr := '5,'+lstr;
  end;
  if ((obj.P_FB=0) and (obj.ST>=0))
    lstr := lstr+',7';
  end;
  if ((obj.CS=1) and (obj.ST<0))
    lstr := lstr+',6';
  end;
  if (obj.BLINK=1)
    lstr := lstr+',10';
  end;
  
  local cmd;
  cmd := obj.name+'.setframes('+lstr+')';
  &&cmd;
  
  if (obj.ST=0)
    obj.selframe(1);
  end;
  
  if (obj.ST=1)
    obj.selframe(3);
  end;
  
  if (obj.ST=2)
    obj.selframe(8);
  end;
  
  if (obj.ST=3)
    obj.selframe(9);
  end;
  
  if (obj.ST=-1)
    obj.selframe(4);
  end;
  
  if (obj.ST=-2)
    obj.selframe(4);
  end;
  
  if (obj.ST=-3)
    obj.selframe(2);
  end;
  
  
  if (obj.ST=10)
    obj.selframe(1);
  end;
  
  if (obj.ST=11)
    obj.selframe(3);
  end;
  
  if (obj.ST=20)
    obj.selframe(1);
  end;
  
  if (obj.ST=21)
    obj.selframe(3);
  end;
  
  if (obj.ST=22)
    obj.selframe(8);
  end;
  
  if (obj.ST=23)
    obj.selframe(9);
  end;
  
  if (obj.ST=30)
    obj.selframe(1);
  end;
  
  if (obj.ST=31)
    obj.selframe(3);
  end;
  
  if (obj.ST=32)
    obj.selframe(8);
  end;
  
  if (obj.ST=33)
    obj.selframe(9);
  end;
  
  if (obj.ST=-12)
    obj.selframe(4);
  end;
  
  if (obj.ST=-13)
    obj.selframe(2);
  end;
  
endf;


function extern DrawIOLink_VK_Valve(obj);
  
  if (obj.State=0)
    obj.setframes(0);
    obj.selframe(1);
  end;
  
  if (obj.State=1)
    obj.setframes(0);
    obj.selframe(3);
  end;
  
  if (obj.State=2)
    obj.setframes(0);
    obj.selframe(8);
  end;
  
  if (obj.State=3)
    obj.setframes(0);
    obj.selframe(9);
  end;
  
  if (obj.State=10)
    obj.setframes(0, 7);
    obj.selframe(1);
  end;
  
  if (obj.State=11)
    obj.setframes(0, 7);
    obj.selframe(3);
  end;
  
  if (obj.State=-1)
    obj.setframes(0);
    obj.selframe(4);
  end;
  
  if (obj.State=-2)
    obj.setframes(0, 6);
    obj.selframe(4);
  end;
  
  if (obj.State=-3)
    obj.setframes(0);
    obj.selframe(2);
  end;
  
  if (obj.State=20)
    obj.setframes(5,0);
    obj.selframe(1);
  end;
  
  if (obj.State=21)
    obj.setframes(5,0);
    obj.selframe(3);
  end;
  
  if (obj.State=22)
    obj.setframes(5,0);
    obj.selframe(8);
  end;
  
  if (obj.State=23)
    obj.setframes(5,0);
    obj.selframe(9);
  end;
  
  if (obj.State=30)
    obj.setframes(5, 0, 7);
    obj.selframe(1);
  end;
  
  if (obj.State=31)
    obj.setframes(5, 0, 7);
    obj.selframe(3);
  end;
  
  if (obj.State=32)
    obj.setframes(5, 0, 7);
    obj.selframe(8);
  end;
  
  if (obj.State=33)
    obj.setframes(5, 0, 7);
    obj.selframe(9);
  end;
  
  if (obj.State=-12)
    obj.setframes(5, 0, 6);
    obj.selframe(4);
  end;
  
  if (obj.State=-13)
    obj.setframes(5, 0);
    obj.selframe(2);
  end;
  
endf;

function extern DrawIOLinkDrValve(self);
  if (self.State=0)
    self.setframes(0);
    self.selframe(1);
  end;
  
  if (self.State=1)
    self.setframes(0);
    self.selframe(3);
  end;
  
  if (self.State=2)
    self.setframes(0);
    self.selframe(8);
  end;
  
  if (self.State=3)
    self.setframes(0);
    self.selframe(9);
  end;
  
  if (self.State=10)
    self.setframes(0, 7);
    self.selframe(1);
  end;
  
  if (self.State=11)
    self.setframes(0, 7);
    self.selframe(3);
  end;
  
  if (self.State=-1)
    self.setframes(0);
    self.selframe(4);
  end;
  
  if (self.State=-2)
    self.setframes(0, 6);
    self.selframe(4);
  end;
  
  if (self.State=-3)
    self.setframes(0);
    self.selframe(2);
  end;
  
  if (self.State=20)
    self.setframes(5,0);
    self.selframe(1);
  end;
  
  if (self.State=21)
    self.setframes(5,0);
    self.selframe(3);
  end;
  
  if (self.State=22)
    self.setframes(5,0);
    self.selframe(8);
  end;
  
  if (self.State=23)
    self.setframes(5,0);
    self.selframe(9);
  end;
  
  if (self.State=30)
    self.setframes(5, 0, 7);
    self.selframe(1);
  end;
  
