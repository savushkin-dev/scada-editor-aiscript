function extern SetBLineInStepStr(obj); //линии наполнения
  local strm;
  strm := '';
  
  if ( ( obj.ST and 1 ) = 1 )
    if (obj.step1 = 1)
      strm := '1.Мойка линии';
    end;
    if (obj.step1 = 2)
      strm := '2.Промывка седел';
    end;
    if (obj.step1 = 3)
      strm := '3.Промывка дренажа';
    end;
    if (obj.step1 = 4)
      strm := '4.Дренаж';
    end;
  end;
  if ( ( obj.ST and 2 ) = 2 )
    if (obj.step2 = 1)
      strm := '1.Ожидание';
    end;
    if (obj.step2 = 2)
      strm := '2.В дренаж';
    end;
    if (obj.step2 = 3)
      strm := '3.В танк 1';
    end;
    if (obj.step2 = 4)
      strm := '4.В танк 2';
    end;
  end;
  obj.Step_Str := strm;
endf;
