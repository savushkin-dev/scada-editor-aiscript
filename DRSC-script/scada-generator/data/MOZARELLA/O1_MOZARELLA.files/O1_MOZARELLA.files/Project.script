    self.setframes(5, 0, 7);
    self.selframe(3);
  end;
  
  if (self.State=32)
    self.setframes(5, 0, 7);
    self.selframe(8);
  end;
  
  if (self.State=33)
    self.setframes(5, 0, 7);
    self.selframe(9);
  end;
  
  if (self.State=-12)
    self.setframes(5, 0, 6);
    self.selframe(4);
  end;
  
  if (self.State=-13)
    self.setframes(5, 0);
    self.selframe(2);
  end;
  
endf;

