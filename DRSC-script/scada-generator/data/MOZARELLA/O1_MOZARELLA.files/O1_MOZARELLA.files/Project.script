function extern SetBrineStepStr(obj); //коагуляторы
  local strm;
  strm := '';
  if ( ( obj.ST and 1 ) = 1 )  //мойка
    if (obj.step1 = 1)
      strm := strm+'1.На МГ';
    end;
    if (obj.step1 = 2)
      strm := strm+'2.Линия наполнения';
    end;
    if (obj.step1 = 3)
      strm := strm+'3.Линия возврата';
    end;
    if (obj.step1 = 4)
      strm := strm+'4.Смена среды';
    end;
    if (obj.step1 = 5)
      strm := strm+'5.Объект опорожнен';
    end;
    if (obj.step1 = 6)
      strm := strm+'6.Дренаж';
    end;
  end;
  
  if ( ( obj.ST and 2 ) = 2 )  //мойка
    if (obj.step2 = 1)
      strm := strm+'1.Заполнение л.циркуляции';
    end;
    if (obj.step2 = 2)
      strm := strm+'2.Ожидание появления уровня';
    end;
    if (obj.step2 = 3)
      strm := strm+'3.Откачка до НУ';
    end;
    if (obj.step2 = 4)
      strm := strm+'4.Появление ВУ';
    end;
    if (obj.step2 = 5)
      strm := strm+'5.Полное опустошение';
      obj.step2_4:=1;
    else
      obj.step2_4:=0;
    end;
  end;
  
  if ( ( obj.ST and 4 ) = 4 )  //
    if (obj.step3 = 1)
      strm := strm+'1.Ожидание появления уровня' + chr(13) + chr(10);
    end;
    if (obj.step3 = 2)
      strm := strm+'2.Откачка до НУ' + chr(13) + chr(10);
    end;
    if (obj.step3 = 3)
      strm := strm+'3.Появление ВУ' + chr(13) + chr(10);
    end;
    if (obj.step3_4 = 1)
      strm := strm + '4.Циркуляция через MF2' + chr(13) + chr(10);
    end;
    if (obj.step3_5 = 1)
      strm := strm + '5.Завершение подачи на MF2' + chr(13) + chr(10);
    end;
    if (obj.step3_6 = 1)
      strm := strm + '6.Завершение выдачи из MF2' + chr(13) + chr(10);
    end;
  end;
  
  if ( ( obj.ST and 8 ) = 8 )  //мойка
    if (obj.step4 = 1)
      strm := strm+'1.Откачка в 4885';
    end;
    if (obj.step4 = 2)
      strm := strm+'2.Откачка из 4885';
    end;
    if (obj.step4 = 3)
      strm := strm+'3.Проталкивание л.циркуляции';
    end;
  end;
  
  obj.Step_Str := strm;
endf;

