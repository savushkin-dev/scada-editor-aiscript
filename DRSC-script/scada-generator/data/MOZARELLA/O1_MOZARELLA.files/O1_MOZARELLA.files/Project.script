function extern SetTable(tnkObj);    //сыроизготовитель и узел подогрева
  tnkObj.R ('RModeTable').ClearJoinList;
  tnkObj.R ('RModeHeatTable').ClearJoinList;
  
  local table, table1;
  
  table := tnkObj.R('RModeTable');
  tnkObj.R('RModeTable').Visible := false;
  
  table1 := tnkObj.R('RModeHeatTable');
  tnkObj.R('RModeHeatTable').Visible := false;
  
  table.ClearJoinList;
  table1.ClearJoinList;
  
  local mix, cmd, num, tnk, cool, line, heat, master, pres;
  num := Str(tnkObj.Nmr, 1);
  
  cmd := 'MasterObj';//master
  master := &&cmd;
  
  cmd := 'CoagHeatingObj' + num;  //узел перемешивания
  heat := &&cmd;
  
  cmd := 'CoagObj' + num;  //коагуляторы
  tnk := &&cmd;
  
  cmd := 'PressObj' + num;  //коагуляторы
  pres := &&cmd;
  
  if ( ( heat.ST and 1 ) = 1 )//ПОДОГРЕВ
    heat.R(table1.name).JoinToProp(heat.name,'S_PAR_F3');
    heat.R(table1.name).JoinToProp(heat.name,'S_PAR_F4');
    heat.R(table1.name).JoinToProp(heat.name,'S_PAR_F5');
  end;
  
  if ( ( pres.ST and 1 ) = 1 )//ПОДОГРЕВ
    pres.R(table1.name).JoinToProp(pres.name,'S_PAR_F3');
    pres.R(table1.name).JoinToProp(pres.name,'S_PAR_F4');
    pres.R(table1.name).JoinToProp(pres.name,'S_PAR_F5');
    pres.R(table1.name).JoinToProp(pres.name,'S_PAR_F6');
  end;
  
  
  if ( ( tnk.ST and 1 ) = 1 )//Мойка КОАГУЛЯТОРА
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F17');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F18');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F20');
  end;
  
  if ( ( tnk.ST and 2 ) = 2 )//Наполнение   КОАГУЛЯТОРА
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F11');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F12');
  end;
  
  
  if (( ( tnk.ST and 4 ) > 0 ) or (tnk.ST = 0) or (( heat.ST and 1 ) > 0 ) or (heat.ST = 0) or (( pres.ST and 1 ) > 0 ) or (pres.ST = 0) ) // Сумма операций, для которых нужна таблица
    tnkObj.R('RModeTable').Visible := true;
    tnkObj.R('RModeHeatTable').Visible := true;
  end;
  
endf;
