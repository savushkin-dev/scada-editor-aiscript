function extern StWork(self);//для отображения старт, стоп, пауза для операций коагулятора
  
  if (self.allocate='C')
    
    if ((self.St=0) or (self.ST2=0) or (self.ST3=0) or (self.ST4=0) or (self.ST5=0) or (self.ST6=0) or (self.ST7=0) or (self.ST8=0) or (self.ST9=0) or (self.ST10=0))
      self.selframe(1);
    end;
    
    if ((self.St=1)  or (self.ST2=1) or (self.ST3=1) or (self.ST4=1) or (self.ST5=1) or (self.ST6=1) or (self.ST7=1) or (self.ST8=1) or (self.ST9=1) or (self.ST10=1))
      self.selframe(2);
    end;
    
    if ((self.St=2) or (self.ST2=2) or (self.ST3=2) or (self.ST4=2) or (self.ST5=2) or (self.ST6=2) or (self.ST7=2) or (self.ST8=2) or (self.ST9=2) or (self.ST10=2))
      self.selframe(3);
    end;
    
    if ((self.St=3) or (self.ST2=3) or (self.ST3=3) or (self.ST4=3) or (self.ST5=3) or (self.ST6=3) or (self.ST7=3) or (self.ST8=3)  or (self.ST9=3) or (self.ST10=3))
      self.selframe(4);
    end;
    
    if ((self.St=4) or (self.ST2=4) or (self.ST3=4) or (self.ST4=4) or (self.ST5=4) or (self.ST6=4) or (self.ST7=4) or (self.ST8=4)  or (self.ST9=4) or (self.ST10=4))
      self.selframe(5);
    end;
    
    if ((self.St=5)or (self.ST2=5) or (self.ST3=5) or (self.ST4=5) or (self.ST5=5) or (self.ST6=5) or (self.ST7=5) or (self.ST8=5)  or (self.ST9=5) or (self.ST10=5))
      self.selframe(6);
    end;
    
  end;
endf;

function extern StWork1(self);//для отображения старт, стоп, пауза для операций коагулятора
  
  if (self.allocate='C')
    
    if ((self.St=0) or (self.ST2=0))
      self.selframe(1);
    end;
    
    if ((self.St=1)  or (self.ST2=1))
      self.selframe(2);
    end;
    
    if ((self.St=2) or (self.ST2=2))
      self.selframe(3);
    end;
    
    if ((self.St=3) or (self.ST2=3) )
      self.selframe(4);
    end;
    
    if ((self.St=4) or (self.ST2=4))
      self.selframe(5);
    end;
    
    if ((self.St=5)or (self.ST2=5) )
      self.selframe(6);
    end;
    
  end;
endf;

function extern SetProd(obj);
  local i, cmd, res;
  cmd := '';
  i := 1;
  while ( i <= ProductCount )
    cmd := cmd + ',"' + ProductType[0, i] + '"';
    i := i + 1;
  end;
  cmd := cmd + ', "Сброс продукта"';
  cmd := cmd[2];
  cmd := 'ShowMenu(' + cmd + ')';
  res := &&cmd;
  if ( res <> -1)
    if ( res = ProductCount )
      obj.S_PAR_F3 := 0;
    else
      obj.S_PAR_F3 := res + 1;
    end;
  end;
  
endf;

