function extern SetLineInStepStr(obj); //линии наполнения
  local strm;
  strm := '';
  //debug;
  if ( ( obj.ST and 1 ) = 1 )
    if (obj.step1 = 1)
      strm := '1.Мойка';
    end;
    if (obj.step1 = 2)
      strm := '2.Промывка седел';
    end;
    if (obj.step1 = 3)
      strm := '3.Промывка дренажа';
    end;
    if (obj.step1 = 4)
      strm := '4.Дренаж';
    end;
  end;
  if ( ( obj.ST and 2 ) = 2 )
    
    if (obj.step2 = 1)
      strm := '1.Ожидание';
    end;
    if (obj.step2 = 2)
      strm := '2.В линию вытеснения ' +chr(13) + chr(10)+ '(В дренаж)';
    end;
    
    if (obj.nmr=1)
      if (obj.step2 = 3)
        strm := '3.В танк 1';
      end;
    else
      if (obj.step2 = 3)
        strm := '3.В линию' +chr(13) + chr(10)+ 'BERTSCH';
      end;
    end;
    
    if (obj.step2 = 4)
      strm := '4.В танк 2';
    end;
    if (obj.step2 = 5)
      strm := '5.В танк 3';
    end;
    if (obj.step2 = 6)
      strm := '6.В танк 4';
    end;
    if (obj.step2 = 7)
      strm := '7.В танк 5';
    end;
    if (obj.step2 = 8)
      strm := '8.Запрос проталкивания';
    end;
  end;
  obj.Step_Str := strm;
endf;

