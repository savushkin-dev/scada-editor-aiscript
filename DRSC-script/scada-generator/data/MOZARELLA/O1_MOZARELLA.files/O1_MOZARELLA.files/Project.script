  if (MESSAGEDLG('Сбросить счетчик ' + self.Name + '?')=1)
    Self.V := 0;
  end;
endf;

function extern DrawMesh(mesh);  //мешалка с реверсом
  if (mesh.allocate='C')
    
    if (mesh.ST=1)
      if (mesh.M = 1)
        mesh.setframes(0,8);
        mesh.selframe(2);
      end;
      if (mesh.M = 0)
        mesh.setframes(0);
        mesh.selframe(2);
      end;
    end;
    
    if (mesh.ST=2)
      if (mesh.M = 1)
        mesh.setframes(6,0,8);
        mesh.selframe(2);
      end;
      if (mesh.M = 0)
        mesh.setframes(0,6);
        mesh.selframe(2);
      end;
    end;
    
    if (mesh.ST=-1)
      mesh.setframes(0);
      mesh.selframe(3);
    end;
    
    if (mesh.ST=0)
      if (mesh.M = 1)
        mesh.setframes(0,8);
        mesh.selframe(1);
      end;
      if (mesh.M = 0)
        mesh.setframes(0);
        mesh.selframe(1);
      end;
    end;
    
  end;
endf;



function extern StWork2(self);//для отображения старт, стоп, пауза для операций коагулятора
  
  if (self.allocate='C')
    
    if ((self.St=0) or (self.ST2=0) or (self.ST3=0) or (self.ST4=0))
      self.selframe(1);
    end;
    
    if ((self.St=1)  or (self.ST2=1) or (self.ST3=1) or (self.ST4=1))
      self.selframe(2);
    end;
    
    if ((self.St=2) or (self.ST2=2) or (self.ST3=2) or (self.ST4=2) )
      self.selframe(3);
    end;
    
    if ((self.St=3) or (self.ST2=3) or (self.ST3=3) or (self.ST4=3) )
      self.selframe(4);
    end;
    
    if ((self.St=4) or (self.ST2=4) or (self.ST3=4) or (self.ST4=4) )
      self.selframe(5);
    end;
    
    if ((self.St=5)or (self.ST2=5) or (self.ST3=5) or (self.ST4=5))
      self.selframe(6);
    end;
    
  end;
endf;

function extern StWork4(self);//для отображения старт, стоп, пауза для операций коагулятора
  
  if (self.allocate='C')
    
