  end;
endf;
function extern LogSFermentationBegin(obj); //obj  внесение закваски
  if (StartLog <> 0)
    
    local cmd, temp1, temp2;
    local Snmr;
    
    if (obj.Nmr <= 3 )
      Snmr := str(obj.Nmr,1);
    else
      Snmr := str(obj.Nmr,2);
    end;
    
    local x;
    x:=VarArrayCreate([0, 10], varVariant);
    x[0]:='operation';
    x[1]:=now;
    x[2]:=0;
    x[3]:=ProjectId;
    x[4]:=obj.WorkCenter;
    x[5]:=27;
    x[6]:=1;
    x[7]:='paramstart';
    x[8]:='P_TE1';
    cmd := 'KOAG' + Snmr + 'TE1';
    temp1 := &&cmd;
    cmd := 'KOAG' + Snmr + 'TE2';
    temp2 := &&cmd;
    x[9]:= (temp1.V + temp2.V) / 2;
    x[10]:='paramend';
    obj.WriteToLog(11, x);
  end;
endf;

