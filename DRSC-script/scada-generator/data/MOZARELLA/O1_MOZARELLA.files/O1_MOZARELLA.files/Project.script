    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F13');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F14');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F31');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F32');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F47');
    
  end;
  
  
  if ( ( tnk.ST and 16 ) = 16 )//ВЫДАЧА
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F13');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F14');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F33');
    tnkObj.R(table.name).JoinToProp(tnk.name,'S_PAR_F34');
  end;
  
  if (( ( tnk.ST and 35 ) > 0 ) or (tnk.ST = 0) or (( cool.ST and 1 ) > 0 ) or (cool.ST = 0)  or (( mix.ST and 1 ) > 0 ) or (mix.ST = 0) ) // Сумма операций, для которых нужна таблица
    tnkObj.R('RModeTableBRN').Visible := true;
    tnkObj.R('RModeCoolTableBRN').Visible := true;
  end;
  
endf;
function extern Menu( self, Type{1 - Tanks, 0 - Wash, 2 - Mesh}, obj );
  {local i, j, k, r;
  local cmd;               //переменная для формирования команд
  local mask;              //переменная для формирования маски для перебора режимов
  local res;               //возвращаемое значение из SHOWMENU
  local canMask;           //маска для формирования ограничений
  local promt;             //переменная для формирования диалога подтверждения вкл/выкл режима
  local menuElementsCnt;   //максимальное количество строк вызываемого меню
  local ModeEnabled;       //массив масок доступных режимов при включенном данном режиме
  local Mode;              //массив названий режимов
  local regimMask;         //текущее состояние объекта
  local cmdTrue;           //флаг разрешения посылки команды в контроллер
  local manual;            //маска доступных режимов в ручном режиме
  local BeginReg;           //начало отсчёта списка режимов
  local BeginMask;         //начальная маска списка режимов
  local startmask, starti, z;
  regimMask:=obj.ST;
  
  if ( Type = 1 ) //линия наполнения мс2
    // ModeEnabled := ModeTankEnabled;
    Mode := modeLineIn1; //бункер
    menuElementsCnt := 2;
    startmask := 1;
    starti :=0;
    canMask := 15;
    // manual := 3;
  end;
  
  
  mask := 1;
  i := 0;
  
  
  
  if ( canMask = 0  ) //Если финальная маска =0 значит где то неправильные маски - ТАКОГО НЕ ДОЛЖНО БЫТЬ!!!
    QOut('Ошибка! Выберите нужный режим вручную!');
    return();
  end;
  //-Если объект танк начало обработки режимов с 0 элемента(и соответствующая начальная маска)
  mask := startmask;
  i := starti;
  //-----------------------------------------------------------------------------------------
  
  j := 0;
  cmd := '';
  
  //-----------------Цикл формирования вызываемого меню--------------------------------------
  while ( i < menuElementsCnt )
    // if ( ( canMask and mask) = mask )  //режим доступен
    if ( ( regimMask and mask) = 0 ) //режим не работает, должно быть 'включить ...'
      cmd := cmd + ',"' + Mode[0,i] + '"';
      enabledElements[0, j] := Mode[0,i];
      enabledElements[1, j] := i;
      j := j + 1;
    else //режим работает, должно быть 'выключить ...'
      cmd := cmd + ',"ОТКЛЮЧИТЬ ' + Mode[0,i] + '"';
      enabledElements[0, j] := 'ОТКЛЮЧИТЬ ' + Mode[0,i];
      enabledElements[1, j] := i;
      j := j + 1;
    end;
    i := i + 1;
    mask := 2*mask;
  end;
  
  cmd := cmd[2]; //Удаляем первую лишнюю зпт
  cmd := 'ShowMenu(' + cmd + ')'; //Формирование команды вызова меню
  res := &&cmd;                   //Вызов меню и получение ответа
  
  if (res <> -1) //Если выбран режим (не нажали крестик)
    mask := 2**enabledElements[1, res]; //маска включаемого режима
    promt := enabledElements[0, res] + '?'; //строка подтверждения выполнения действия
    if ( (regimMask and mask) = 0 )         // режим не включен
      if (MESSAGEDLG(promt)=1)    //запрос на подтверждение вкл режима
        cmdTrue:=1;
      end;
      if (cmdTrue=1) //если параметры записались
        obj.cmd := 1001 + enabledElements[1, res]; //посылка команды на выполнение
      end;
    else
      mask := not mask;
      if (MESSAGEDLG(promt)=1)
        obj.cmd := 2001 + enabledElements[1, res];
      end;
    end;
    end;}
  endf;
  
  
  {function extern LogSWashBegin(obj);  //запись прослеживаемости старт мойки
  if (StartLog <> 0)
    local x;
    x:=VarArrayCreate([0, 8], varVariant);
    x[0]:='operation';
    x[1]:=now;
    x[2]:=0;
    x[3]:=projectId;
    x[4]:=obj.WorkCenter;
    x[5]:=31;
    x[6]:=1;
    x[7]:='paramstart';
    x[8]:='paramend';
    obj.WriteToLog(11, x);
  end;
endf;
