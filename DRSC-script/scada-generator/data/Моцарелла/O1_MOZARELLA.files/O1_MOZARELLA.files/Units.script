  modeNumStr := SUBSTR(objName, pos+1);
  modeNum := VAL(modeNumStr);
  modeL := modeWash;
  
  
  local i;
  
  if (buttObj.ST = 0)
    if (MESSAGEDLG('Включить операцию "'+modeL[0, modeNum-1]+'"?')=1)
      mainObj.CMD:=1000 + modeNum;
    end;
  end;
  
  if (buttObj.ST = 1)
    i:=ShowMenu('Пауза','Стоп');
    if ( i = 0 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в паузу?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
      end;
    end;
    if ( i = 1 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
      end;
    end;
  end;
  
  if (buttObj.ST = 2)
    i:=ShowMenu('Выполнение','Стоп');
    if ( i = 0 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в выполнение?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 1;
      end;
    end;
    
    if ( i = 1 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
      end;
    end;
  end;
  
  if (buttObj.ST = 3)
    if (MESSAGEDLG('Выключить операцию "'+modeL[0, modeNum-1]+'" ?')=1)
      mainObj.CMD:=2000 + modeNum;
    end;
  end;
endf;
function extern OnInitiateSetWTHeat(Self,Msg);
local objName, cmd, buttObj, mainObj, modeL;
local modeNum,  modeNumStr, mainObjNum, mainObjNumStr;
objName := Msg[0];
buttObj := &&objName;
mainObjNum := buttObj.Nmr;

if (mainObjNum < 10)
  mainObjNumStr := str(mainObjNum, 1);
else
  mainObjNumStr := str(mainObjNum, 2);
end;

cmd := 'HeatObj1';// + mainObjNumStr;
mainObj := &&cmd;

local pos;
pos := AT('M', objName);

modeNumStr := SUBSTR(objName, pos+1);
modeNum := VAL(modeNumStr);
modeL := modeHeating;


local i;

if (buttObj.ST = 0)
  if (MESSAGEDLG('Включить операцию "'+modeL[0, modeNum-1]+'"?')=1)
    mainObj.CMD:=1000 + modeNum;
  end;
end;

if (buttObj.ST = 1)
  i:=ShowMenu('Пауза','Стоп');
  if ( i = 0 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в паузу?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
  if ( i = 1 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
end;

if (buttObj.ST = 2)
  i:=ShowMenu('Выполнение','Стоп');
  if ( i = 0 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в выполнение?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 1;
    end;
  end;
  
  if ( i = 1 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
end;

if (buttObj.ST = 3)
  if (MESSAGEDLG('Выключить операцию "'+modeL[0, modeNum-1]+'" ?')=1)
    mainObj.CMD:=2000 + modeNum;
  end;
end;

endf;
function extern OnInitiateUprMaster(Self,Msg);
local cmd, obj, opNum, opNmr, opSt, btnType, modes, lineobj;
local tankNum, tnkNmr, tnkObj;
local i, j, k, l, m, cmdTrue;   //test l, m
local enabledElm;//test

//btnType -Тип кнопки управления 1-Старт, 2-Пауза, 3-Стоп.
btnType := Msg[0];
opNum := Msg[1];

if (opNum <10)
  opNmr := str(opNum, 1);
else
  opNmr := str(opNum, 2);
end;
//debug;
modes := modeMaster;
cmd := 'MasterObj';
obj := &&cmd;
opSt := &&(Obj.name + '.OPERATIONS' + opNmr);

if (btnType = 1)
  if (opST = 0)
    if ((opNum >0) and (opNum <2))
      //debug;
      tankNum:= opNum-0; //Получаем номер танка, для кот вкл-т Приготовление партии
      if (tankNum <10)
        tnkNmr := str(tankNum, 1);//строковое зн-ие номера танка
      else
        tnkNmr := str(tankNum, 2);
      end;
      
      //cmd := 'TankObj'+tnkNmr;
      cmd := 'CoagObj'+tnkNmr;
      tnkobj := &&cmd;
      
      if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
        //test
        qout ('Необходимо указать номер партии!');
        
        i:=EditFK('Номер партии:', tnkObj.S_PAR_F7,0,1000,0);
        j:=EditFK('Номер партии:', tnkObj.S_PAR_F12,0,5000,0);
        if (MESSAGEDLG('Включить Приготовление партии в танке ' + tnkNmr+' с параметрами:'+ chr(13) +chr(10) +
          'Номер партии - ' + str(i,4)+ chr(13) +chr(10)+ //)=1)
          'Количество продукта при наполнении танка - '+ str(j,6)+' кг ?')=1)
          tnkObj.ClearRc('SetParams');
          tnkObj.AddRcPar('SetParams',tnkObj.name,'S_PAR_F7',i);
          tnkObj.AddRcPar('SetParams',tnkObj.name,'S_PAR_F12',j);
          if (!tnkObj.StartNewRc('SetParams'))
            qout('Не удалось загрузить рецепт!');
            cmdTrue := 0;
          end;
          cmdTrue := 1;
        else
          cmdTrue := 0;
        end;
        //end;
        
      end;
      if (cmdTrue = 1)
        obj.CMD:=1000 + opNum;
      end;
    else
      if((opNum =6) or (opNum =15) or (opNum =16))
      if (opNum =6)
        cmd := 'LineInObj1';
        lineobj := &&cmd;
      end;
      if (opNum =15)
        cmd := 'LineInObj2';
        lineobj := &&cmd;
      end;
      if (opNum =16)
        cmd := 'LineInObj3';
        lineobj := &&cmd;
      end;
      
      if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
        if ((MESSAGEDLG('Использовать ли бачок лимонной кислоты?')=1))
          cmdTrue := 1;
          j:=1;
        else
          j:=0;
        end;
        if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?' +'с параметром: Флаг использования бачка лимонной кислоты = '+ str(j,1)+' ')=1)
          lineObj.ClearRc('SetParams');
          lineObj.AddRcPar('SetParams',lineObj.name,'S_PAR_F7',j);
          if (!lineObj.StartNewRc('SetParams'))
            qout('Не удалось загрузить рецепт!');
            cmdTrue := 0;
          end;
          cmdTrue := 1;
        else
          cmdTrue := 0;
        end;
        
        if (cmdTrue = 1)
          obj.CMD:=1000 + opNum;
        end;
      end;
      
    else
      if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
        obj.CMD:=1000 + opNum;
      end;
    end;
    
    
  end;
  
end;

if (opST = 1)
  qout('Операция находится в состоянии Выполнения!');
end;
if (opST = 2)
  if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние выполнения?')=1)
    obj.CMD:=(1000 + opNum) * 100 +1;
  end;
end;
if (opST = 3)
  qout('Операция находится в состоянии Стоп!');
end;

end;

if (btnType = 2)
  if (opST = 0)
    qout('Операция выключена!');
  end;
  if (opST = 1)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние паузы?')=1)
      obj.CMD:=(1000 + opNum) * 100 +2;
    end;
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние выполнения?')=1)
      obj.CMD:=(1000 + opNum) * 100 +1;
    end;
  end;
  if (opST = 3)
    qout('Операция находится в состоянии Стоп!');
  end;
end;

if (btnType = 3)
  if (opST = 0)
    qout('Операция выключена!');
  end;
  if (opST = 1)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние Стоп?')=1)
      obj.CMD:=(1000 + opNum) * 100 +3;
    end;
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние Стоп?')=1)
      obj.CMD:=(1000 + opNum) * 100 + 3;
    end;
  end;
  if (opST = 3)
    if (MESSAGEDLG('Выключить операцию "'+modes[0, opNum-1]+'"?')=1)
      obj.CMD:=2000 + opNum;
    end;
  end;
end;

endf;
function extern OnInitiateUprMasterBRN(Self,Msg);
local cmd, obj, opNum, opNmr, opSt, btnType, modes;
local tankNum, BRNtankNum, tnkNmr, tnkObj;
local i, j, k, l, m, cmdTrue;   //test l, m
local enabledElm;//test

//btnType -Тип кнопки управления 1-Старт, 2-Пауза, 3-Стоп.
btnType := Msg[0];
opNum := Msg[1];

if (opNum <10)
  opNmr := str(opNum, 1);
else
  opNmr := str(opNum, 2);
end;
//debug;
modes := modeMaster;
cmd := 'MasterObj';
obj := &&cmd;
opSt := &&(Obj.name + '.OPERATIONS' + opNmr);

if (btnType = 1)
  if (opST = 0)
    if ((opNum >8) and (opNum <11))
      
      BRNtankNum:= opNum-8; //Получаем номер танка, для кот вкл-т Приготовление партии
      if (BRNtankNum <10)
        tnkNmr := str(BRNtankNum, 1);//строковое зн-ие номера танка
      else
        tnkNmr := str(BRNtankNum, 2);
      end;
      
      //cmd := 'TankObj'+tnkNmr;  
      cmd := 'FBrineTankObj'+tnkNmr;
      tnkobj := &&cmd;
      
      if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
        //test
        qout ('Необходимо указать номер партии и количество продукта при наполнении (кг)!');
           
          i:=EditFK('Номер партии:', tnkObj.S_PAR_F7,0,1000,0); 
          j:=EditFK('Количество продукта при наполнении:', tnkObj.S_PAR_F12,0,2000,0);
          if (MESSAGEDLG('Включить Приготовление партии в танке ' + tnkNmr+' с параметрами:'+ chr(13) +chr(10) +
         'Номер партии - ' + str(i,4)+ chr(13) +chr(10)+ //)=1) 
          'Количество продукта при наполнении танка - '+ str(j,6)+' кг ?')=1)
            tnkObj.ClearRc('SetParams');
            tnkObj.AddRcPar('SetParams',tnkObj.name,'S_PAR_F7',i);
            tnkObj.AddRcPar('SetParams',tnkObj.name,'S_PAR_F12',j);
            if (!tnkObj.StartNewRc('SetParams'))
              qout('Не удалось загрузить рецепт!');
              cmdTrue := 0;
            end;
            cmdTrue := 1;
          else
            cmdTrue := 0;
          end;
        //end;
        
      end;
      if (cmdTrue = 1)
        obj.CMD:=1000 + opNum;
      end;
  else
    if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
      obj.CMD:=1000 + opNum;
    end;
      
    end;//пока раб
    
  end;
    
  if (opST = 1)
    qout('Операция находится в состоянии Выполнения!');
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние выполнения?')=1)
      obj.CMD:=(1000 + opNum) * 100 +1;
    end;
  end;
  if (opST = 3)
    qout('Операция находится в состоянии Стоп!');
  end;
  
end;

if (btnType = 2)
  if (opST = 0)
    qout('Операция выключена!');
  end;
  if (opST = 1)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние паузы?')=1)
      obj.CMD:=(1000 + opNum) * 100 +2;
    end;
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние выполнения?')=1)
      obj.CMD:=(1000 + opNum) * 100 +1;
    end;
  end;
  if (opST = 3)
    qout('Операция находится в состоянии Стоп!');
  end;
end;

if (btnType = 3)
  if (opST = 0)
    qout('Операция выключена!');
  end;
  if (opST = 1)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние Стоп?')=1)
      obj.CMD:=(1000 + opNum) * 100 +3;
    end;
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние Стоп?')=1)
      obj.CMD:=(1000 + opNum) * 100 + 3;
    end;
  end;
  if (opST = 3)
    if (MESSAGEDLG('Выключить операцию "'+modes[0, opNum-1]+'"?')=1)
      obj.CMD:=2000 + opNum;
    end;
  end;
end;

endf;
function extern OnInitiateUprMasterWT(Self,Msg);
local cmd, obj, opNum, opNmr, opSt, btnType, modes;
local tankNum, BRNtankNum, tnkNmr, tnkObj;
local i, j, k, l, m, cmdTrue;   //test l, m
local enabledElm;//test

//btnType -Тип кнопки управления 1-Старт, 2-Пауза, 3-Стоп.
btnType := Msg[0];
opNum := Msg[1];

if (opNum <10)
  opNmr := str(opNum, 1);
else
  opNmr := str(opNum, 2);
end;
//debug;
modes := modeMaster;
cmd := 'MasterObj';
obj := &&cmd;
opSt := &&(Obj.name + '.OPERATIONS' + opNmr);

if (btnType = 1)
  if (opST = 0)
    if ((opNum >16) and (opNum <21))
      
      tankNum:= opNum-16; //Получаем номер танка, для кот вкл-т Приготовление партии
      if (BRNtankNum <10)
        tnkNmr := str(tankNum, 1);//строковое зн-ие номера танка
      else
        tnkNmr := str(tankNum, 2);
      end;
      
      //cmd := 'TankObj'+tnkNmr;
      cmd := 'TankObjWT'+tnkNmr;
      tnkobj := &&cmd;
      
      if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
        //test
        qout ('Необходимо указать номер партии и количество продукта при наполнении (кг)!');
        
        i:=EditFK('Номер партии:', tnkObj.S_PAR_F4,0,1000,0);
        j:=EditFK('Количество продукта при наполнении:', tnkObj.S_PAR_F11,0,2000000,0);
        if (MESSAGEDLG('Включить Приготовление партии в танке ' + tnkNmr+' с параметрами:'+ chr(13) +chr(10) +
          'Номер партии - ' + str(i,4)+ chr(13) +chr(10)+ //)=1)
          'Количество продукта при наполнении танка - '+ str(j,7)+' кг ?')=1)
          tnkObj.ClearRc('SetParams');
          tnkObj.AddRcPar('SetParams',tnkObj.name,'S_PAR_F4',i);
          tnkObj.AddRcPar('SetParams',tnkObj.name,'S_PAR_F11',j);
          if (!tnkObj.StartNewRc('SetParams'))
            qout('Не удалось загрузить рецепт!');
            cmdTrue := 0;
          end;
          cmdTrue := 1;
        else
          cmdTrue := 0;
        end;
        //end;
        
      end;
      if (cmdTrue = 1)
        obj.CMD:=1000 + opNum;
      end;
    else
      if (MESSAGEDLG('Включить операцию "'+modes[0, opNum-1]+'"?')=1)
        obj.CMD:=1000 + opNum;
      end;
      
    end;
    
  end;
  
  if (opST = 1)
    qout('Операция находится в состоянии Выполнения!');
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние выполнения?')=1)
      obj.CMD:=(1000 + opNum) * 100 +1;
    end;
  end;
  if (opST = 3)
    qout('Операция находится в состоянии Стоп!');
  end;
  
end;

if (btnType = 2)
  if (opST = 0)
    qout('Операция выключена!');
  end;
  if (opST = 1)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние паузы?')=1)
      obj.CMD:=(1000 + opNum) * 100 +2;
    end;
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние выполнения?')=1)
      obj.CMD:=(1000 + opNum) * 100 +1;
    end;
  end;
  if (opST = 3)
    qout('Операция находится в состоянии Стоп!');
  end;
end;

if (btnType = 3)
  if (opST = 0)
    qout('Операция выключена!');
  end;
  if (opST = 1)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние Стоп?')=1)
      obj.CMD:=(1000 + opNum) * 100 +3;
    end;
  end;
  if (opST = 2)
    if (MESSAGEDLG('Перевести операцию "'+modes[0, opNum-1]+'" в состояние Стоп?')=1)
