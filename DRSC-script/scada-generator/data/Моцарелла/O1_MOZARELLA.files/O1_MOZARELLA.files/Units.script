function extern OnClickRefl3525(Self,SelfR);
local par, nmr, cmd, tnkObj;

nmr := str(prj.TnkNum,1);
//debug;
cmd:='TankObj'+nmr;
tnkObj:=&&cmd;

par := EditFK('Введите заданное количество литров:', tnkObj.S_PAR_F8, 0, 150000, 0);
if ( par <> tnkObj.S_PAR_F8 )
  tnkObj.S_PAR_F8 := par;
end;
endf;

