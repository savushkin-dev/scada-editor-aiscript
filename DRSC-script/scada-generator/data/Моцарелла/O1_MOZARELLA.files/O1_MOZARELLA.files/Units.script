  if ( ( self.ST and 1048576 ) = 1048576 )
    ladd := 105;
  end;
  
  if ( ( self.ST and 2097152 ) = 2097152 )
    ladd := 110;
  end;
  if ( ( self.ST and 4194304 ) = 4194304 )
    ladd := 115;
  end;
