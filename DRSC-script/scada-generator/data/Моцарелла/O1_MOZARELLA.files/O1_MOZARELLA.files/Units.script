function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeWB;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[1, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;
  //prj.BtnVisible(self); 
  
    if ( (self.Nmr = prj.TnkNum) and (self.ActiveMap.MapName == 'Production' ))
    prj.SetTable( self );
  end;
end;

{if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ladd + 10;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;}
if (self.Allocate = 'S')
  
  local ladd;
  ladd := 0;
  
  if ( ( self.ST and 1 ) = 1 )
    ladd := 5;
    
  end;
  if ( ( self.ST and 2 ) = 2 )
    ladd := 10;
  end;
  if ( ( self.ST and 4 ) = 4 )
    ladd := 15;
  end;
  if ( ( self.ST and 8 ) = 8 )
    ladd := 20;
  end;
  if ( ( self.ST and 16 ) = 16 )
    ladd := 25;
  end;
  if ( ( self.ST and 32 ) = 32 )
    ladd := 30;
  end;
  if ( ( self.ST and 64 ) = 64 )
    ladd := 35;
  end;
  
  if ( ( self.ST and 128 ) = 128 )
    ladd := 40;
    
  end;
  if ( ( self.ST and 256 ) = 256 )
    ladd := 45;
  end;
  if ( ( self.ST and 512 ) = 512 )
    ladd := 50;
  end;
  if ( ( self.ST and 1024 ) = 1024 )
    ladd := 55;
  end;
  if ( ( self.ST and 2048 ) = 2048 )
    ladd := 60;
  end;
  if ( ( self.ST and 4096 ) = 4096 )
    ladd := 65;
  end;
  if ( ( self.ST and 8192 ) = 8192 )
    ladd := 70;
  end;
  
  if ( ( self.ST and 16384 ) = 16384 )
    ladd := 75;
    
  end;
  if ( ( self.ST and 32768 ) = 32768 )
    ladd := 80;
  end;
  if ( ( self.ST and 65536 ) = 65536 )
    ladd := 85;
  end;
  if ( ( self.ST and 131072 ) = 131072 )
    ladd := 90;
  end;
  if ( ( self.ST and 262144 ) = 262144 )
    ladd := 95;
  end;
  if ( ( self.ST and 524288 ) = 524288 )
    ladd := 100;
  end;
  if ( ( self.ST and 1048576 ) = 1048576 )
    ladd := 105;
  end;
  
  if ( ( self.ST and 2097152 ) = 2097152 )
    ladd := 110;
  end;
  if ( ( self.ST and 4194304 ) = 4194304 )
    ladd := 115;
  end;
  if ( ( self.ST and 8388608 ) = 8388608 )
    ladd := 120;
  end;
  
  if ( ( self.ST and 16777216 ) = 16777216 )
    ladd := 125;
  end;
  if ( ( self.ST and 33554432 ) = 33554432 )
    ladd := 130;
  end;
  if ( ( self.ST and 67108864 ) = 67108864 )
    ladd := 135;
  end;
  if ( ( self.ST and 134217728 ) = 134217728 )
    ladd := 140;
  end;
  if ( ( self.ST and 26843546 ) = 26843546 )
    ladd := 145;
  end;
  if ( ( self.ST and 536870912 ) = 536870912 )
    ladd := 150;
  end;
  if ( ( self.ST and 1073741824 ) = 1073741824 )
    ladd := 155;
  end;
  
  
  self.Ladder := ladd;
  
end;
endf;
