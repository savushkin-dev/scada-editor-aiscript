function extern OnChangeS_PAR_F1(Self);
if (self.allocate = 'C')
 local wh;
 local wmin;
 local wsec;
 
 wh := Int( self.S_PAR_F1/3600000 );
 wmin := Int(( self.S_PAR_F1 - wh*3600000)/60000 );
 wsec := Int( (self.S_PAR_F1  - wh*3600000 - wmin*60000)/1000 );

 
 self.Time_Str := Str(wh, 2) + ":" + Str(wmin, 2) + ":" + Str(wsec, 2);
end;
endf;
function extern OnChangeS_PAR_F2(Self);
if (self.allocate = 'C')
 local wh;
 local wmin;
 local wsec;
 
 wh := Int( self.S_PAR_F2/3600000 );
 wmin := Int(( self.S_PAR_F2 - wh*3600000)/60000 );
 wsec := Int( (self.S_PAR_F2  - wh*3600000 - wmin*60000)/1000 );

 
 self.Step_Time_Str := Str(wh, 2) + ":" + Str(wmin, 2) + ":" + Str(wsec, 2);
end;
endf;
function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeCool;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[0, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;

  if ( (self.Nmr = prj.TnkNum) and (self.ActiveMap.MapName == 'Production' ))
    prj.SetTable( self );
  end;

end;

{if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ladd + 10;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;}
if (self.Allocate = 'S')
  
  local ladd;
  ladd := 0;
  
  if ( ( self.ST and 1 ) = 1 )
    ladd := 12;  
  end;
  
  self.Ladder := ladd;
  
end;
endf;
function extern OnChangestep1(Self);
if (self.allocate='C')
  prj.SetPCoolStepStr(self);
end;
endf;
function extern OnInitiateSetSTEXStr(Self,Msg);
  local cmd, op, num, i, strm, mode, opstate;
  strm := '';
  mode := prj.modeCool;
  opstate:=prj.opStates;
  i := 1;
  while(i<2)
  if (i < 10)
    num := str(i, 1);
  else
    num := str(i, 2);
  end;
  cmd := self.name+'.OPERATIONS'+num;
  op := &&cmd;
  if (op <> 0)
    strm :=  strm + mode[0, (i-1)]+chr(13)+chr(10)+
' ('+opstate[0, op]+')'+chr(13)+chr(10);
    
  end;
  
  i := i+1;
end;
self.STEX_Str := strm;
endf;
