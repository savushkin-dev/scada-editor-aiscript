//--------------- Begin: P4840V11 ---------------;
function extern OnChangeState(Self);
if (self.allocate='C')
  
  if (self.State=0)
    self.setframes(0);
    self.selframe(1);
  end;

  if (self.State=1)
    self.setframes(0);
    self.selframe(3);
  end;
  
  if (self.State=2)
    self.setframes(0);
    self.selframe(8);
  end; 
  
  if (self.State=3)
    self.setframes(0);
    self.selframe(9);
  end;
  
  if (self.State=10)
    self.setframes(0, 7);
    self.selframe(1);
  end;

  if (self.State=11)
    self.setframes(0, 7);
    self.selframe(3);
  end;
  
  if (self.State=-1)
    self.setframes(0);
    self.selframe(4);
  end;
  
  if (self.State=-2)
    self.setframes(0, 6);
    self.selframe(4);
  end;

  if (self.State=-3)
    self.setframes(0);
    self.selframe(2);
  end;             

  if (self.State=20)
    self.setframes(5,0);
    self.selframe(1);
  end;

  if (self.State=21)
    self.setframes(5,0);
    self.selframe(3);
  end;
  
  if (self.State=22)
    self.setframes(5,0);
    self.selframe(8);
  end;
  
  if (self.State=23)
    self.setframes(5,0);
    self.selframe(9);
  end;
     
  if (self.State=30)
    self.setframes(5, 0, 7);
