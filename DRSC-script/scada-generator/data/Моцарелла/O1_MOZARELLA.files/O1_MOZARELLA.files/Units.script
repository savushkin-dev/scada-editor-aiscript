function extern OnChangeS_PAR_F1(Self);
if (self.allocate = 'C')
 local wh;
 local wmin;
 local wsec;

 wh := Int( self.S_PAR_F1/3600000 );
 wmin := Int(( self.S_PAR_F1 - wh*3600000)/60000 );
 wsec := Int( (self.S_PAR_F1  - wh*3600000 - wmin*60000)/1000 );

 
 self.Time_Str := Str(wh, 2) + ":" + Str(wmin, 2) + ":" + Str(wsec, 2);
end;
endf;
function extern OnChangeS_PAR_F2(Self);
if (self.allocate = 'C')
