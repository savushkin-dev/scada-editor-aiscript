  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeHeating;//операции узла подогрева
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[0, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;

  //if ( (self.Nmr = prj.TnkNum) and (self.ActiveMap.MapName == 'Production' ))
   // prj.SetTable( self );
  //end;

end;

{
if (self.Allocate = 'S')
  
  local ladd;
  ladd := 0;
  
  if ( ( self.ST and 1 ) = 1 )
    ladd := 8;  
  end;
  
  self.Ladder := ladd;
  
end;}
if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ii*5 + 5;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;
endf;
function extern OnChangestep1(Self);
if (self.allocate='C')
  prj.SetPHeatStepStr(self);
end;

endf;
function extern OnInitiateSetSTEXStr(Self,Msg);
  local cmd, op, num, i, strm, mode, opstate;
  strm := '';
  mode := prj.modeHeating;//операции узла подогрева
  opstate:=prj.opStates;
  i := 1;
  while(i<2)
  if (i < 10)
    num := str(i, 1);
  else
    num := str(i, 2);
  end;
  cmd := self.name+'.OPERATIONS'+num;
  op := &&cmd;
  if (op <> 0)
    strm :=  strm + mode[0, (i-1)]+chr(13)+chr(10)+
' ('+opstate[0, op]+')'+chr(13)+chr(10);
    
  end;
  
  i := i+1;
end;
self.STEX_Str := strm;
endf;
