Num := val( reflname[5,2] );
modeNum := val( reflname[9,2] );
parNum := val(reflname[13, 2]);
parVal := val(reflname[17, 2]);

local Message;
Message := [Num, modeNum, parNum, parVal];
PSF.SetLineInParamsReg(Message);}
endf;

