//--------------- Begin: FBrineLineInObj1 ---------------;
//---StaticFunctionsBegin
function StatePar(self);
  if (self.Allocate = 'C')
    local tnkNmr, cmd, i,lamp, lNmr;
    
    if (self.Nmr < 10)
      lNmr := str(self.Nmr, 1);
    else
      lNmr := str(self.Nmr, 2);
    end;
    
   // debug;
    
    if (((self.step1 = 0) or (self.step1 = 1) or (self.step1 = 2)) and (self.S_PAR_F10 <> 0))  //2
       i := 1;
      while ( i <= prj.TankSCountBRN)//< 10)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F10)
           cmd := &&(self.name + '.WIn'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.WIn'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
      if ((self.S_PAR_F10 < 0)  and (self.step1 <> 2))  //2
        cmd := &&(self.name + '.WDren := 1');
      else
        cmd := &&(self.name + '.WDren := 0');
      end;
      
    else
      
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 10)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.WIn'+tnkNmr +' := 0');
        i:= i +1;
      end;
      cmd := &&(self.name + '.WDren := 0');
    end;
    //debug;
    if ((self.step1 >= 1 ) and (self.S_PAR_F10 <> 0 )) //2
    //if ((self.step2 = (2 + self.S_PAR_F5 - 1 ) ) and (self.S_PAR_F5 <> 0 ))
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F10)
          cmd := &&(self.name + '.In'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.In'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
    else
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.In'+tnkNmr +' := 0');
        i:= i +1;
      end;
    end;
    
    if (self.step1 = 2)//2
      self.Dren := 1;
    else
      self.Dren := 0;
    end;
  end;
endf;
//---StaticFunctionsEnd
function extern OnChangemode1(Self);
{if (self.allocate='S')
  if (self.mode1=1)
    prj.LogSWashBegin(self);
  else
    prj.LogSWashEnd(self);
  end;
end;}
endf;
function extern OnChangeOPERATIONS1(Self);
if (self.allocate = 'C')
   self.SetSTEXStr(1); 
end;
endf;
function extern OnChangeS_PAR_F1(Self);
if (self.allocate = 'C')
 local wh;
 local wmin;
 local wsec;

 wh := Int( self.S_PAR_F1/3600000 );
 wmin := Int(( self.S_PAR_F1 - wh*3600000)/60000 );
 wsec := Int( (self.S_PAR_F1  - wh*3600000 - wmin*60000)/1000 );

 
 self.Time_Str := Str(wh, 2) + ":" + Str(wmin, 2) + ":" + Str(wsec, 2);
end;
endf;
function extern OnChangeS_PAR_F10(Self);
if (self.allocate = 'C')
  StatePar(self);  
end;
endf;
function extern OnChangeS_PAR_F2(Self);
if (self.allocate = 'C')
 local wh;
 local wmin;
 local wsec;

