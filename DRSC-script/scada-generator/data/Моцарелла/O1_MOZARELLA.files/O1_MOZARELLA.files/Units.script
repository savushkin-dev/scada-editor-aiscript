function extern OnInitiateEditNumTankWT(Self,Msg);
local AO, prom, cmd, mst, p, res, i, j, cmdtrue;
local nmr, parNmr, par, parRes;
local num, parNum, tnkNmr, lastpar, firstpar, tankselements, tanksisp;
local lobj;

tankselements := array(2);
tanksisp := array(2);

num := Msg[0];
parNum := Msg[1];
cmdTrue := 0;
if (num < 10)
  nmr := str(num , 1);
else
  nmr := str(num , 2);
end;

cmd:='MasterObj';
mst := &&cmd;

if (parnum < 10)
  parnmr := str(parnum , 1);
else
  parnmr := str(parnum , 2);
end;

par := &&(mst.name +'.S_PAR_F'+parNmr);

firstpar := parnum - num + 1;     // № 1 параметра из ряда для задания очереди

//-------------------------------------------
if (firstpar<38)
  cmd:='LineInObjWT1';
  lobj:=&&cmd;
end;

if ((firstpar>37) and (firstpar<41))
  cmd:='LineOutObjWT1';
  lobj:=&&cmd;
end;
//--------------------------------------------

cmd:= '';

if (par=0)
  
  i:=0;
  
  //debug;
  while (i<2)
    if ((firstpar + i) < 10)
      p:=&&(mst.name +'.S_PAR_F'+str(firstpar + i , 1));
    else
      p:=&&(mst.name +'.S_PAR_F'+str(firstpar + i , 2));
    end;
    if (p <> 0)
      tanksisp[i]:=p;
      i := i + 1;
    else
      i := i + 1;
    end;
  end;
  i:=1;
  j:=0;
  //debug;
  while (i<2)
    if ((ASCAN(tanksisp,i)) = -1)
      cmd := cmd + ',"' + tanksWT[i-1] + '"';
      tankselements[j]:= i;
      i := i + 1;
      j := j + 1;
    else
      i := i + 1;
    end;
  end;
  //debug;
  if ((ASCAN(tanksisp,-10))= -1)
    cmd := cmd + ',"' + tanksWT[1]+'"';
    tankselements[j]:= (ASCAN(tanksisp,-1)*10);
  end;
  cmd := cmd[2];
  cmd := 'ShowMenu(' + cmd + ')';
  res := &&cmd;
  //debug;
  if ( res <> -1)
    if (tankselements[res]<-1)
      
      {if ((MESSAGEDLG('Заданный объем подачи в линию - '+ str(lobj.S_PAR_F11, 6)+' л,?')=1))
        cmdTrue := 1;
      else
        j:=EditFK('Заданный объем подачи (л):', lobj.S_PAR_F11,0,100000,0);
        lobj.ClearRc('SetParams');
        lobj.AddRcPar('SetParams',lobj.name,'S_PAR_F11',j);
        if (!lobj.StartNewRc('SetParams'))
          qout('Не удалось загрузить рецепт!');
          cmdTrue := 0;
        end;
        cmdTrue := 1;
      end;
      if (cmdTrue = 1) }
        parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '-10');
      //end;
      
    else
      if (res < 10)
        parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ str(tankselements[res],1));
      else
        parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ str(tankselements[res],2));
      end;
    end;
  end;
else
  
  prom :='Сбросить номер танка?';
  
  if (MESSAGEDLG(prom) = 1 )
    parRes := &&(mst.name +'.S_PAR_F'+parNmr +' := 0');
  end;
  
end;

endf;
function extern OnInitiateEditNumTankWTP(Self,Msg);
local AO, prom, cmd, mst, p, res, i, j, cmdtrue;
local nmr, parNmr, par, parRes;
local num, parNum, tnkNmr, lastpar, firstpar, tankselements, tanksisp;
local lobj;
local flag;

tankselements := array(3);
tanksisp := array(3);

num := Msg[0];
parNum := Msg[1];
cmdTrue := 0;
if (num < 10)
  nmr := str(num , 1);
else
  nmr := str(num , 2);
end;

cmd:='MasterObj';
mst := &&cmd;

if (parnum < 10)
  parnmr := str(parnum , 1);
else
  parnmr := str(parnum , 2);
end;

par := &&(mst.name +'.S_PAR_F'+parNmr);

firstpar := parnum - num + 1;     // № 1 параметра из ряда для задания очереди

//-------------------------------------------
if (firstpar<38)
  cmd:='LineInObjWT1';
  lobj:=&&cmd;
end;
//--------------------------------------------

cmd:= '';

if (par=0)
  
  i:=0;
  
  while (i<3)
    if ((firstpar + i) < 10)
      p:=&&(mst.name +'.S_PAR_F'+str(firstpar + i , 1));
    else
      p:=&&(mst.name +'.S_PAR_F'+str(firstpar + i , 2));
    end;
    if (p <> 0)
      tanksisp[i]:=p;
      i := i + 1;
    else
      i := i + 1;
    end;
  end;
  flag:=100;
  //debug;
  if ((ASCAN(tanksisp,1))>= 0)
    cmd := cmd + ',"' + tanksWTP[1]+'"';
    flag:=1;
  else
    if ((ASCAN(tanksisp,-1))>= 0)
      cmd := cmd + ',"' + tanksWTP[0]+'"';
      flag:=-1;
    else
      if ((ASCAN(tanksisp,-10))>= 0)
        qout('В очереди установлен шаг "Циркуляция" - другие объекты не доступны');
        flag:=0;
      else
        cmd := cmd + ',"' + tanksWTP[0]+'"';
        cmd := cmd + ',"' + tanksWTP[1]+'"';
        cmd := cmd + ',"' + tanksWTP[2]+'"';
        flag:=100;
      end;
    end;
  end;
  
  
  if (flag<>0)
    cmd := cmd[2];
    cmd := 'ShowMenu(' + cmd + ')';
    res := &&cmd;
    if ( res <> -1)
      if (flag=100)
        if (res=0) parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '1'); end;
        if (res=1) parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '-1'); end;
        if (res=2) parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '-10'); end;
      else
        if (flag=1)
          if (res=0) parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '-1'); end;
        else
          if (flag=-1)
            if (res=0) parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '1'); end;
          end;
        end;
      end;
    end;
    
  end;
  
else
  
  prom :='Сбросить номер танка?';
  
  if (MESSAGEDLG(prom) = 1 )
    parRes := &&(mst.name +'.S_PAR_F'+parNmr +' := 0');
  end;
  
end;

endf;
function extern OnInitiateSetB3Reg(Self,Msg);

local objName, cmd, buttObj, mainObj, modeL;
  local modeNum,  modeNumStr, mainObjNum, mainObjNumStr;
  //debug;
  objName := Msg[0];
  buttObj := &&objName;
  mainObjNum := buttObj.Nmr;
  
  if (mainObjNum < 10)
    mainObjNumStr := str(mainObjNum, 1);
  else
    mainObjNumStr := str(mainObjNum, 2);
  end;
  
  cmd := 'BRN3LineObj1'; // + mainObjNumStr;
  mainObj := &&cmd;
  
  local pos;
  pos := AT('M', objName);
  
  modeNumStr := SUBSTR(objName, pos+1);
  modeNum := VAL(modeNumStr);
  modeL := modeWB;
  
  
  local i;
  
  if (buttObj.ST = 0)
    if (MESSAGEDLG('Включить операцию "'+modeL[0, modeNum-1]+'"?')=1)
      mainObj.CMD:=1000 + modeNum;
    end;
  end;
  
  if (buttObj.ST = 1)
    i:=ShowMenu('Пауза','Стоп');
    if ( i = 0 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в паузу?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
      end;
    end;
    if ( i = 1 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
      end;
    end;
  end;
  
  if (buttObj.ST = 2)
    i:=ShowMenu('Выполнение','Стоп');
    if ( i = 0 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в выполнение?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 1;
      end;
    end;
    
    if ( i = 1 )
      if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
        mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
      end;
    end;
  end;
  
  if (buttObj.ST = 3)
