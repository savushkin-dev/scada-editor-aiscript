function extern OnClickRefl3488(Self,SelfR);
selfr.CancelPress;
local cmd, line;
cmd:='BrineTankObj1';
line:=&&cmd;
if (line.step2_4 = 0)
  if (MESSAGEDLG('Включить "Полное опустошение в 4885"?')=1)
    line.cmd:=1105;
  end;
else
  qout('Шаг выключается автоматически!');
end;
endf;

