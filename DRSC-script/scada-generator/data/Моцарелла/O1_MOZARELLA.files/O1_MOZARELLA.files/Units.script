end;}

endf;
function extern OnChangeS_PAR_F9(Self);
if (self.allocate ='C')
  if (self.S_PAR_F9 = 1) 
   self.R('R_FI' +str(self.nmr, 1)+ '_H' +str(self.nmr, 1)).visible:=true;
  else
    self.R('R_FI' +str(self.nmr, 1)+ '_H' +str(self.nmr, 1)).visible:=false;
  end;
end;
endf;
function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeLineInFBrine;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[0, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;
  
  {prj.SetLineStr(TankObj1,TankObj2,TankObj3,TankObj4, 
  LineInObj1,LineInObj2,LineInObj3,
  LineOutObj1,LineOutObj2
  );}
end;
if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ii*5 + 5;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;

endf;
function extern OnChangestep1(Self);
if (self.allocate='C')
  prj.SetFBrineLineInStepStr(self);
   StatePar(self);
end;
endf;
function extern OnInitiateSetSTEXStr(Self,Msg);
  local cmd, op, num, i, strm, mode, opstate;
  strm := '';
  mode := prj.modeLineInFBrine;
  opstate:=prj.opStates;
  i := 1;
  while(i<2)
  if (i < 10)
    num := str(i, 1);
  else
    num := str(i, 2);
  end;
  cmd := self.name+'.OPERATIONS'+num;
  op := &&cmd;
  if (op <> 0)
    strm :=  strm + mode[0, (i-1)]+chr(13)+chr(10)+
' ('+opstate[0, op]+')'+chr(13)+chr(10);
    
  end;
  
  i := i+1;
end;
self.STEX_Str := strm;
endf;
//--------------- End: FBrineLineInObj1 ---------------;
//--------------- Begin: FBrineLineOutObj1 ---------------;
//---StaticFunctionsBegin
function StatePar(self);     //линии выдачи операция выдачи
  //debug;
  if (self.Allocate = 'C')
    local tnkNmr, cmd, i, lNmr;
    
    if (self.Nmr < 10)
      lNmr := str(self.Nmr, 1);
    else
      lNmr := str(self.Nmr, 2);
    end;
    
    if (((self.step2 = 0) or (self.step2 = 1) or (self.step2 = 2)) and (self.S_PAR_F3 <> 0))
      
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 10)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F3)
          
          cmd := &&(self.name + '.WOut'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.WOut'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
      if ((self.S_PAR_F3 < 0)  and (self.step2 <> 2))
        cmd := &&(self.name + '.WProt := 1');
      else
        cmd := &&(self.name + '.WProt := 0');
      end;
      
    else
      
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.WOut'+tnkNmr +' := 0');
        i:= i +1;
      end;
      cmd := &&(self.name + '.WProt := 0');
    end;
    
    if ((self.step2 > 1 ) and (self.S_PAR_F3 <> 0 ))   //>2
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 6)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F3)
          cmd := &&(self.name + '.Out'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.Out'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
    else
      i := 1;
      while ( i <= prj.TankSCountBRN)//< 6)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.Out'+tnkNmr +' := 0');
        i:= i +1;
      end;
    end;
    
  end;
  
  if (self.step2 = 2)
    self.Prot := 1;
  else
    self.Prot := 0;
  end;
endf;

