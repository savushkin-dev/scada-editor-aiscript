function StatePar(self);     //линии выдачи операция выдачи
  //debug;
  if (self.Allocate = 'C')
    local tnkNmr, cmd, i, lNmr;
    
    if (self.Nmr < 10)
      lNmr := str(self.Nmr, 1);
    else
      lNmr := str(self.Nmr, 2);
    end;
    
    if (((self.step2 = 0) or (self.step2 = 1) or (self.step2 = 2)) and (self.S_PAR_F8 <> 0))
      
      i := 1;
      while ( i <= prj.TankSCount)//< 10)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F8)
          
          cmd := &&(self.name + '.WOut'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.WOut'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
      if ((self.S_PAR_F8 < 0)  and (self.step2 <> 2))
        cmd := &&(self.name + '.WProt := 1');
      else
        cmd := &&(self.name + '.WProt := 0');
      end;
      
    else
      
      i := 1;
      while ( i <= prj.TankSCount)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.WOut'+tnkNmr +' := 0');
        i:= i +1;
      end;
      cmd := &&(self.name + '.WProt := 0');
    end;
    
    if ((self.step2 > 1 ) and (self.S_PAR_F8 <> 0 ))   //>2
      i := 1;
      while ( i <= prj.TankSCount)//< 6)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F8)
          cmd := &&(self.name + '.Out'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.Out'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
    else
      i := 1;
      while ( i <= prj.TankSCount)//< 6)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.Out'+tnkNmr +' := 0');
        i:= i +1;
      end;
    end;
    
  end;
  
  if (self.step2 = 2)
    self.Prot := 1;
  else
    self.Prot := 0;
  end;
endf;
