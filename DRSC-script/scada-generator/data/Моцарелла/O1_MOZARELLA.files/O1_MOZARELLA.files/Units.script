//---StaticFunctionsBegin
function StatePar(self);
  if (self.Allocate = 'C')
    local tnkNmr, cmd, i,lamp, lNmr;
    
    if (self.Nmr < 10)
      lNmr := str(self.Nmr, 1);
    else
      lNmr := str(self.Nmr, 2);
    end;
    
   // debug;
    
    if (((self.step2 = 0) or (self.step2 = 1) or (self.step2 = 2)) and (self.S_PAR_F10 <> 0))  //2
       i := 1;
      while ( i <= prj.TankSCount)//< 10)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F10)
           cmd := &&(self.name + '.WIn'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.WIn'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
      if ((self.S_PAR_F10 < 0)  and (self.step2 <> 2))  //2
        cmd := &&(self.name + '.WDren := 1');
      else
        cmd := &&(self.name + '.WDren := 0');
      end;
      
    else
      
      i := 1;
      while ( i <= prj.TankSCount)//< 10)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.WIn'+tnkNmr +' := 0');
        i:= i +1;
      end;
      cmd := &&(self.name + '.WDren := 0');
    end;
    //debug;
    if ((self.step2 > 2 ) and (self.S_PAR_F10 <> 0 )) //2
    //if ((self.step2 = (2 + self.S_PAR_F5 - 1 ) ) and (self.S_PAR_F5 <> 0 ))
      i := 1;
      while ( i <= prj.TankSCount)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F10)
          cmd := &&(self.name + '.In'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.In'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
    else
      i := 1;
      while ( i <= prj.TankSCount)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.In'+tnkNmr +' := 0');
        i:= i +1;
      end;
    end;
    
    if (self.step2 = 2)//2
      self.Dren := 1;
    else
      self.Dren := 0;
    end;
  end;
endf;
