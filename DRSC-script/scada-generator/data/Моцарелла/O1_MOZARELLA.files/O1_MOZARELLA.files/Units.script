function extern OnChangestate(Self);
if (self.allocate='C')
  
  if (self.State=1)
    self.setframes(0);
    self.selframe(2);
  end;
  
  if (self.State=0)
    self.setframes(0);
    self.selframe(1);
  end;
  
  if (self.State=-1)
    self.setframes(0);
    self.selframe(3);
  end;
  
  if (self.State=10)
    self.setframes(0, 6);
    self.selframe(1);
  end;

  if (self.State=11)
    self.setframes(0, 6);
    self.selframe(2);
  end;
  
  if (self.State=-2)
    self.setframes(0, 7);
    self.selframe(8);
  end;

  if (self.State=-3)
    self.setframes(0);
    self.selframe(3);
  end;             

  if (self.State=21)
    self.setframes(4,0);
    self.selframe(2);
  end;
  
  if (self.State=20)
    self.setframes(4,0);
    self.selframe(1);
  end;
  
  {if (self.State=-11)
    self.setframes(4,0);
    self.selframe(3);
  end;  }
  
  if (self.State=30)
    self.setframes(4, 0, 6);
    self.selframe(1);
  end;

  if (self.State=31)
    self.setframes(4, 0, 6);
    self.selframe(2);
  end;
  
  if (self.State=-12)
    self.setframes(4, 0, 7);
    self.selframe(8);
  end;

  if (self.State=-13)
    self.setframes(4, 0);
    self.selframe(3);
  end;                         
  
end;

endf;
