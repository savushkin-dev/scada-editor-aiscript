//---StaticFunctionsBegin
function StatePar(self);
  //debug;
  if (self.Allocate = 'C')
    local tnkNmr, cmd, i, lNmr;
    
    if (self.Nmr < 10)
      lNmr := str(self.Nmr, 1);
    else
      lNmr := str(self.Nmr, 2);
    end;
    
    if (((self.step2 = 0) or (self.step2 = 1) or (self.step2 = 2)) and (self.S_PAR_F4 <> 0))
      
      i := 1;
      while ( i <= 1)//< 10)
        tnkNmr := str(i, 1);
        if ( i <> self.S_PAR_F4)
          cmd := &&(self.name + '.WOut'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.WOut'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
      if ((self.S_PAR_F4 < 0)  and (self.step2 <> 2))
        cmd := &&(self.name + '.WProt := 1');
      else
        cmd := &&(self.name + '.WProt := 0');
      end;
      
    else
      
      i := 1;
      while ( i <= 1)//< 29)
        tnkNmr := str(i, 1);
        cmd := &&(self.name + '.WOut'+tnkNmr +' := 0');
        i:= i +1;
      end;
      cmd := &&(self.name + '.WProt := 0');
    end;
    
    if ((self.step2 > 2 ) and (self.S_PAR_F4 <> 0 ))
      i := 1;
      while ( i <= 1)//< 6)
        tnkNmr := str(i, 1);
        if ( i <> self.S_PAR_F4)
          cmd := &&(self.name + '.Out'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.Out'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
    else
      i := 1;
      while ( i <= 1)//< 6)
        tnkNmr := str(i, 1);
        cmd := &&(self.name + '.Out'+tnkNmr +' := 0');
        i:= i +1;
      end;
    end;
    
  end;
  
  if (self.step2 = 2)
    self.Prot := 1;
  else
    self.Prot := 0;
  end;
endf;
