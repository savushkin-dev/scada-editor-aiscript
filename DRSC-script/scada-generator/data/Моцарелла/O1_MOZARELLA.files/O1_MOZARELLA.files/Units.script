mainObjNum := buttObj.Nmr;

if (mainObjNum < 10)
  mainObjNumStr := str(mainObjNum, 1);
else
  mainObjNumStr := str(mainObjNum, 2);
end;

cmd := 'P4835HeatObj1';// + mainObjNumStr;
mainObj := &&cmd;

local pos;
pos := AT('M', objName);

modeNumStr := SUBSTR(objName, pos+1);
modeNum := VAL(modeNumStr);
modeL := modeHeating;


local i;

if (buttObj.ST = 0)
  if (MESSAGEDLG('Включить операцию "'+modeL[0, modeNum-1]+'"?')=1)
    mainObj.CMD:=1000 + modeNum;
  end;
end;

if (buttObj.ST = 1)
  i:=ShowMenu('Пауза','Стоп');
  if ( i = 0 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в паузу?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
  if ( i = 1 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
end;

if (buttObj.ST = 2)
  i:=ShowMenu('Выполнение','Стоп');
  if ( i = 0 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в выполнение?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 1;
    end;
  end;
  
  if ( i = 1 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
end;

if (buttObj.ST = 3)
  if (MESSAGEDLG('Выключить операцию "'+modeL[0, modeNum-1]+'" ?')=1)
    mainObj.CMD:=2000 + modeNum;
  end;
end;

