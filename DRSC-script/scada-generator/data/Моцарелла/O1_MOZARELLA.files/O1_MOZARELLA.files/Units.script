  if (self.S_PAR_F9 = 1) 
   self.R('R_BI' +str(self.nmr, 1)+ '_H' +str(self.nmr, 1)).visible:=true;
  else
    self.R('R_BI' +str(self.nmr, 1)+ '_H' +str(self.nmr, 1)).visible:=false;
  end;
end;
endf;
function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeBLineIn;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[0, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;
  
  {prj.SetLineStr(TankObj1,TankObj2,TankObj3,TankObj4, 
  LineInObj1,LineInObj2,LineInObj3,
  LineOutObj1,LineOutObj2
  );}
end;
if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ii*5 + 5;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;

endf;
function extern OnChangestep1(Self);
if (self.allocate='C')
  prj.SetBLineInStepStr(self);
end;
endf;
function extern OnChangestep2(Self);
if (self.allocate='C')
  prj.SetBLineInStepStr(self);
  StatePar(self); 
end;
endf;
function extern OnInitiateSetSTEXStr(Self,Msg);
  local cmd, op, num, i, strm, mode, opstate;
  strm := '';
  mode := prj.modeBLineIn;
  opstate:=prj.opStates;
  i := 1;
  while(i<3)
  if (i < 10)
    num := str(i, 1);
  else
    num := str(i, 2);
  end;
  cmd := self.name+'.OPERATIONS'+num;
  op := &&cmd;
  if (op <> 0)
    strm :=  strm + mode[0, (i-1)]+chr(13)+chr(10)+
' ('+opstate[0, op]+')'+chr(13)+chr(10);
    
  end;
  
  i := i+1;
end;
self.STEX_Str := strm;
endf;
