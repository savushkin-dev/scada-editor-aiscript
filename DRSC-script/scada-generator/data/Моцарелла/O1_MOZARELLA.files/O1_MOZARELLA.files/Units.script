  end;
  if ( ( self.ST and 512 ) = 512 )
    ladd := 50;
  end;
  if ( ( self.ST and 1024 ) = 1024 )
    ladd := 55;
  end;
  if ( ( self.ST and 2048 ) = 2048 )
    ladd := 60;
  end;
  if ( ( self.ST and 4096 ) = 4096 )
    ladd := 65;
