function extern OnClickRModeCapt01(Self,SelfR);
local objNum, objNmr, modeNum, modeNmr, refName;
//debug;
objNum := prj.TnkObjBtnStart + prj.TnkNum;

if (objNum < 10)
  objNmr := str(objNum,1);
else
  objNmr := str(objNum,2);
end;

refname := selfr.rname;
modeNum := val(refname[10,2]);

if (modeNum < 10)
  modeNmr := str(modeNum,1);
else
  modeNmr := str(modeNum,2);
end;

local message, objName;

objName :='OBJ'+objNmr+'_M'+modeNmr;
Message := [objName];
PSF.SetTankRegim(Message);endf;

