function extern OnInitiateSetBLineInParReg(Self,Msg);
local num, modeNum, parNum, parVal, cmd, par, objName, mode, parName;
local nmr, promt, modeL;
local tnkObj;

num := Msg[0];
modeNum := Msg[1];
parNum := Msg[2];
parVal := Msg[3];

modeL := modeBLineIn;

if (num < 10)
  nmr := str(num, 1);
else
  nmr := str(num, 2);
end;

objName := 'BRNLineInObj' + nmr;


if (modeNum < 10)
  nmr := str(modeNum, 1);
else
  nmr := str(modeNum, 2);
end;

mode := &&(objName + '.mode' + nmr);


if (parNum < 10)
  nmr := str(parNum, 1);
else
  nmr := str(parNum, 2);
end;
//debug;
parName := objName + '.S_PAR_F'+nmr;
par := &&parName;

if (parVal < 10)
  nmr := str(parVal, 1);
else
  nmr := str(parVal, 2);
end;

if (parVal <> (30)) //+26

   cmd:= 'BRNLineInObj'+ nmr; //test
   tnkobj :=&&objName;    //test 
   
  if (tnkObj.S_PAR_F9<>0)//test 
  if ((mode <> 0) and (par = parVal))
    promt := 'Исключить танк №'+nmr+ ' из работы операции "' + modeL[0, modeNum-1] + '"?';
    if (MESSAGEDLG(promt)=1)
      cmd := &&(parName + ' := 0');
    end;
  else
    if(par <> parVal)
    promt := 'Выбрать танк №'+nmr+ ' для операции "' + modeL[0, modeNum-1] + '"?';
    if (MESSAGEDLG(promt)=1)
      cmd := &&(parName + ' := ' + nmr);
    end;
  else
    promt := 'Исключить танк №'+nmr+ ' из работы операции "' + modeL[0, modeNum-1] + '"?';
    if (MESSAGEDLG(promt)=1)
      cmd := &&(parName + ' := 0');
    end;
    end;
  end;
      else //test
      qout ('Включена работа очереди!!!'); //test
   end;
else
 cmd:= 'BRNLineInObj'+ nmr; //test
 tnkobj :=&&objName;    //test 
   
 if (tnkObj.S_PAR_F9<>0)//test 
if(par <> -1)

promt := 'Включить шаг "Дренаж"?"';
if (MESSAGEDLG(promt)=1)
  cmd := &&(parName + ' := -1');
end;
else
promt := 'Выключить шаг "Дренаж""?"';
if (MESSAGEDLG(promt)=1)
  cmd := &&(parName + ' := 0');
end;
end;
   else //test
      qout ('Включена работа очереди!!!'); //test
   end;
end;

endf;
function extern OnInitiateSetBLineInReg(Self,Msg);

local objName, cmd, buttObj, mainObj, modeL;
local modeNum,  modeNumStr, mainObjNum, mainObjNumStr, parNum, parNmr, par;
//debug;
objName := Msg[0];

buttObj := &&objName;

mainObjNum := buttObj.Nmr;

if (mainObjNum < 10)
  mainObjNumStr := str(mainObjNum, 1);
else
  mainObjNumStr := str(mainObjNum, 2);
end;

cmd := 'BRNLineInObj' + mainObjNumStr;
mainObj := &&cmd;

local pos;
pos := AT('M', objName);

modeNumStr := SUBSTR(objName, pos+1);
modeNum := VAL(modeNumStr);
modeL := modeBLineIn;

par := -1;

if (modeNum = 2)//Наполнение, выдача//2
  parNum := Msg[1];//1
  if (parNum < 10)
    parNmr := str(parNum, 1);
  else
    parNmr := str(parNum, 2);
  end;
  par := &&('BRNLineInObj' + mainObjNumStr + '.S_PAR_F' +parNmr);
end;


local i;

if (buttObj.ST = 0)
  if (par = 0)
  qout('Укажите объект для операции "'+modeL[0, modeNum-1]+'"!');
  else
    if (MESSAGEDLG('Включить операцию "'+modeL[0, modeNum-1]+'"?')=1)
      mainObj.CMD:=1000 + modeNum;
    end;
    
  end;
end;

if (buttObj.ST = 1)
  i:=ShowMenu('Пауза','Стоп');
  if ( i = 0 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в паузу?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
  if ( i = 1 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
end;

if (buttObj.ST = 2)
  i:=ShowMenu('Выполнение','Стоп');
  if ( i = 0 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в выполнение?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 1;
    end;
  end;
  
  if ( i = 1 )
    if (MESSAGEDLG('Перевести операцию "'+modeL[0, modeNum-1]+'" в стоп?')=1)
      mainObj.CMD:=(1000 + modeNum) * 100 + i + 2;
    end;
  end;
end;

if (buttObj.ST = 3)
  if (MESSAGEDLG('Выключить операцию "'+modeL[0, modeNum-1]+'" ?')=1)
    mainObj.CMD:=2000 + modeNum;
  end;
end;

endf;
