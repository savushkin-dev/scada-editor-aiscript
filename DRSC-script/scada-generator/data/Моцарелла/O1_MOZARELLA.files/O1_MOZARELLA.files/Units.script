    self.selframe(1);
  end;

  if (self.State=11)
    self.setframes(0, 7);
    self.selframe(3);
  end;
  
  if (self.State=-1)
    self.setframes(0);
    self.selframe(4);
  end;
  
  if (self.State=-2)
    self.setframes(0, 6);
    self.selframe(4);
  end;

  if (self.State=-3)
    self.setframes(0);
    self.selframe(2);
  end;             

  if (self.State=20)
    self.setframes(5,0);
    self.selframe(1);
  end;

  if (self.State=21)
    self.setframes(5,0);
    self.selframe(3);
