function extern OnChangeState(Self);
if (self.allocate='C') 

if (self.State=10)   //авария
  self.selframe(6);
end;

{if (self.State=11)   //ручной режим
  self.selframe(7, 0);
end;}

if (self.State = 11)
      self.setframes(7,2);
   else
      self.setframes(0);
end;

if (self.State=1)     //насос работает
   self.selframe(2);
 {self.animate:=true;
else
 self.animate:=false;} 
end;

if (self.State=0)   //насос не работает
  self.selframe(1);
end;

end;

endf;
