    ladd := 40;
    
  end;
  if ( ( self.ST and 256 ) = 256 )
    ladd := 45;
  end;
  if ( ( self.ST and 512 ) = 512 )
    ladd := 50;
  end;
  if ( ( self.ST and 1024 ) = 1024 )
    ladd := 55;
  end;
  if ( ( self.ST and 2048 ) = 2048 )
    ladd := 60;
  end;
  if ( ( self.ST and 4096 ) = 4096 )
    ladd := 65;
  end;
  if ( ( self.ST and 8192 ) = 8192 )
    ladd := 70;
  end;
  
  if ( ( self.ST and 16384 ) = 16384 )
    ladd := 75;
    
  end;
  if ( ( self.ST and 32768 ) = 32768 )
    ladd := 80;
