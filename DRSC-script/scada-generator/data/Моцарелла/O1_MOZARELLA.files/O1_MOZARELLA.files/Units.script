function extern OnClickR_Pid_Hand(Self,SelfR);
selfr.cancelpress;
local obj, cmd;

if (prj.pid = 7)
  cmd := 'WR1FC1';
  obj := &&cmd;
end;

if (prj.pid = 8)
  cmd := 'HEATER1TC1';
  obj := &&cmd;
end;

if (prj.pid = 9)
  cmd := 'HEATER1TC2';
  obj := &&cmd;
end;

if ( obj.MP_is_manual_mode = 0 )
  if ( MESSAGEDLG( 'Включить ручной режим?' ) = 1 )
    obj.MP_is_manual_mode := 1;
  end;
else
  if ( MESSAGEDLG( 'Выключить ручной режим?' ) = 1 )
    obj.MP_is_manual_mode := 0;
  end;
end;
endf;

