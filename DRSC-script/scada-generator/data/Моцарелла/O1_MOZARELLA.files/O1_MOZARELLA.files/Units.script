function extern OnClickR_VInPZ(Self,SelfR);
local par, nmr, cmd, tnkObj;

nmr := str(prj.TnkNum,1);
//debug;
cmd:='CoagObj'+nmr;
tnkObj:=&&cmd;

par := EditFK('Введите заданное количество литров:', tnkObj.S_PAR_F12, 0, 5000, 0);
if ( par <> tnkObj.S_PAR_F12 )
  tnkObj.S_PAR_F12 := par;
end;
endf;

function extern OnClickR_VInPZBRN(Self,SelfR);
