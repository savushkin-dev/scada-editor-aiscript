function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeFBRN;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[1, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;
  
    if ( (self.Nmr = prj.TnkNum) and (self.ActiveMap.MapName == 'ProductionBRN' ))
    prj.SetTableBRN( self );
  end;
end;

