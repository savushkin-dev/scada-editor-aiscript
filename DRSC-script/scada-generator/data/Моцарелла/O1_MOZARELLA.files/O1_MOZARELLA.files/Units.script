function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeTank;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[1, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm;
  //prj.BtnVisible(self); 
  
    if ( (self.Nmr = prj.TnkNum) and (self.ActiveMap.MapName == 'Production' ))
    prj.SetTable( self );
  end;
end;

{if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ladd + 10;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;}
if (self.Allocate = 'S')
  
  local ladd;
  ladd := 0;
  
  if ( ( self.ST and 1 ) = 1 )
    ladd := 5;
    
  end;
  if ( ( self.ST and 2 ) = 2 )
    ladd := 10;
  end;
