function extern OnInitiateEditNumTank(Self,Msg);
local AO, prom, cmd, mst, p, res, i, j;
local nmr, parNmr, par, parRes;
local num, parNum, tnkNmr, lastpar, firstpar, tankselements, tanksisp;

tankselements := array(prj.TanksCount+1);
tanksisp := array(prj.TanksCount+1);

num := Msg[0];
parNum := Msg[1];

if (num < 10)
  nmr := str(num , 1);
else
  nmr := str(num , 2);
end;

cmd:='MasterObj';
mst := &&cmd;

if (parnum < 10)
  parnmr := str(parnum , 1);
else
  parnmr := str(parnum , 2);
end;

par := &&(mst.name +'.S_PAR_F'+parNmr);

firstpar := parnum - num + 1;     // № 1 параметра из ряда для задания очереди

cmd:= '';

if (par=0)
  
  i:=0;
  
  //debug;
  while (i<3)
    if ((firstpar + i) < 10)
      p:=&&(mst.name +'.S_PAR_F'+str(firstpar + i , 1));
    else
      p:=&&(mst.name +'.S_PAR_F'+str(firstpar + i , 2));
    end;
    if (p <> 0)
      tanksisp[i]:=p;
      i := i + 1;
    else
      i := i + 1;
    end;
  end;
  i:=1;
  j:=0;
  //debug;
  while (i<3)
    if ((ASCAN(tanksisp,i)) = -1)
      cmd := cmd + ',"' + tanks[i-1] + '"';
      tankselements[j]:= i;
      i := i + 1;
      j := j + 1;
    else
      i := i + 1;
    end;
  end;
{ debug; 
  if ((ASCAN(tanksisp,-1))= -1)
    cmd := cmd + ',"' + tanks [prj.TanksCount+2]+'"';
    tankselements[j]:= (ASCAN(tanksisp,-1));
  end;}
  
  cmd := cmd[2];
  cmd := 'ShowMenu(' + cmd + ')';
  res := &&cmd;
  
  if ( res <> -1)
     if (tankselements[res]=prj.TanksCount+1)
      parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ '-1');
    else
    if (res < 10)
      parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ str(tankselements[res],1));
    else
      parRes := &&(mst.name +'.S_PAR_F' + parNmr +' := '+ str(tankselements[res],2));
    end;
  end;     
end;
else
  
  prom :='Сбросить номер танка?';
  
  if (MESSAGEDLG(prom) = 1 )
    parRes := &&(mst.name +'.S_PAR_F'+parNmr +' := 0');
  end;
  
end;

endf;
