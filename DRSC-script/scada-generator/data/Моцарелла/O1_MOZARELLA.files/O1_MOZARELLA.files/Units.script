function extern OnInitiateSetSTEXStr(Self,Msg);
  local cmd, op, num, i, strm, mode, opstate;
  strm := '';
  mode := prj.modeMaster;
  opstate:=prj.opStates;
  i := 1;
  while(i<15) //20 //<16 //30
  if (i < 10)
    num := str(i, 1);
  else
    num := str(i, 2);
  end;
  cmd := self.name+'.OPERATIONS'+num;
  op := &&cmd;
  if (op <> 0)
    strm :=  strm + mode[0, (i-1)]+' ('+opstate[0, op]+')'+chr(13)+chr(10);
  end;
  i := i+1;
end;
self.STEX_Str := strm;
endf;
//--------------- End: MasterObj ---------------;
