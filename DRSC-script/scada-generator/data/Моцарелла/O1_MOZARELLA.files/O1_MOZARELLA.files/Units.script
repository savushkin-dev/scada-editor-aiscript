function extern OnChangeST(Self);
if (self.allocate = 'C')
  local i, state, isModeUse, mode, strm;
  state := self.ST;
  i := 0;
  mode := prj.modeLineOut;
  strm := '';
  while (i < 31)
    isModeUse := state mod 2;
    state := state div 2;
    if (isModeUse = 1 )
      strm :=  strm + mode[0, i]+chr(13)+chr(10);
    end;                                         
    i := i + 1;
  end;
  
  self.St_str := strm; 
  
   {prj.SetLineStr(TankObj1,TankObj2,TankObj3,TankObj4, 
  LineInObj1,LineInObj2,LineInObj3,
  LineOutObj1,LineOutObj2
  );}
end;

if (self.allocate = 'S')
  local ii, statei, isModeUsei, ladd;
  statei := self.ST;
  ii := 0;
  ladd:= 0;
  while (ii < 31)
    isModeUsei := statei mod 2;
    statei := statei div 2;
    if (isModeUsei = 1 )
      ladd :=  ii*5 + 5;
    end;                                         
    ii := ii + 1;
  end;
  
  self.Ladder := ladd;
end;
