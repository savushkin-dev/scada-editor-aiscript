function extern OnInitiateSetLOParamsReg(Self,Msg);
local num, modeNum, parNum, parVal, cmd, par, objName, mode, parName, obj;
local nmr, promt, modeL;
local tnkobj;

num := Msg[0];
modeNum := Msg[1];
parNum := Msg[2];
parVal := Msg[3];

modeL := modeLineOut;

if (num < 10)
  nmr := str(num, 1);
else
  nmr := str(num, 2);
end;

objName := 'LineOutObj' + nmr;
cmd := 'LineOutObj' + nmr;
obj:=&&cmd;


if (modeNum < 10)
  nmr := str(modeNum, 1);
else
  nmr := str(modeNum, 2);
end;

mode := &&(objName + '.mode' + nmr);


if (parNum < 10)
  nmr := str(parNum, 1);
else
  nmr := str(parNum, 2);
end;

parName := objName + '.S_PAR_F'+nmr;
par := &&parName;

if (parVal < 10)
  nmr := str(parVal, 1);
else
  nmr := str(parVal, 2);
end;

//debug;
if (parVal <> (30))
//if (parVal <> (prj.TanksCount+1)) //+26

cmd := 'LineOutObj'+nmr;//test
tnkobj :=&&objName;   //test
 if (tnkObj.S_PAR_F6<>0)//test
  if ((mode <> 0) and (par = parVal) )
    promt := 'Исключить танк №'+nmr+ ' из работы операции "' + modeL[0, modeNum-1] + '"?';
    if (MESSAGEDLG(promt)=1)
      cmd := &&(parName + ' := 0');
    end;
  else
    if(par <> parVal)
    promt := 'Выбрать танк №'+nmr+ ' для операции "' + modeL[0, modeNum-1] + '"?';
    if (MESSAGEDLG(promt)=1)
        cmd := &&(parName + ' := ' +nmr);
      end;
   // end;
    //----------------------------------------------
  else
    promt := 'Исключить танк №'+nmr+ ' из работы операции "' + modeL[0, modeNum-1] + '"?';
    if (MESSAGEDLG(promt)=1)
      cmd := &&(parName + ' := 0');
    end;
  end;
end;
  else //test
      qout('Включена работа очереди!!!' );//test
    end;//test 
    
else
cmd := 'LineOutObj'+nmr;//test
tnkobj :=&&objName;
 if (tnkObj.S_PAR_F6<>0)//test
if(par <> -1)

promt := 'Включить шаг "Проталкивание"?"';
if (MESSAGEDLG(promt)=1)
  cmd := &&(parName + ' := -1');
end;
else
promt := 'Выключить шаг "Проталкивание"?"';
if (MESSAGEDLG(promt)=1)
  cmd := &&(parName + ' := 0');
end;
  
//end;//test
end;
  else //test
      qout('Включена работа очереди!!!' );//test
    end;//test
end;

endf;
