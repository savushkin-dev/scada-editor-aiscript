  if (self.St=0)
    self.selframe(1);
  end;

  if (self.St=1)
    self.selframe(2);
  end;

  if (self.St=2)
    self.selframe(3);
  end;

  if (self.St=3)
    self.selframe(4);
  end;

  if (self.St=4)
    self.selframe(5);
  end;

  if (self.St=5)
    self.selframe(6);
  end;
   
end;

endf;
