        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.WIn'+tnkNmr +' := 0');
        i:= i +1;
      end;
      cmd := &&(self.name + '.WDren := 0');
    end;
    //debug;
    if ((self.step2 > 2 ) and (self.S_PAR_F10 <> 0 )) //2
    //if ((self.step2 = (2 + self.S_PAR_F5 - 1 ) ) and (self.S_PAR_F5 <> 0 ))
      i := 1;
      while ( i <= prj.TankSCount)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        if ( i <> self.S_PAR_F10)
          cmd := &&(self.name + '.In'+tnkNmr +' := 0');
        else
          cmd := &&(self.name + '.In'+tnkNmr +' := 1');
        end;
        i:= i +1;
      end;
    else
      i := 1;
      while ( i <= prj.TankSCount)//< 29)
        if (i<10)
          tnkNmr := str(i, 1);
        else
          tnkNmr := str(i, 2);
        end;
        cmd := &&(self.name + '.In'+tnkNmr +' := 0');
        i:= i +1;
      end;
    end;
   
    if (self.step2 = 3)
      self.InL := 1;
    else
      self.InL := 0;
    end;
    
    if (self.step2 = 2)//2
      self.Dren := 1;
    else
      self.Dren := 0;
    end;
  end;
endf;
