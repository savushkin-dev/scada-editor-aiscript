function extern OnInitiateSetSTEXStr(Self,Msg);
  local cmd, op, num, i, strm, mode, opstate, m_str;
  strm := '';
  m_str := '';
  mode := prj.modeTank;
  opstate:=prj.opStates;
  i := 1;
  while(i<3)  //14
  if (i < 10)
    num := str(i, 1);
  else
    num := str(i, 2);
  end;
  cmd := self.name+'.OPERATIONS'+num;
  op := &&cmd;
  if (op <> 0)
    strm :=   strm + mode[0, (i-1)]+ chr(13)+chr(10) +  ' ('+opstate[0, op]+')';
    m_str :=   m_str + mode[0, (i-1)]+ chr(13)+chr(10) +  '('+opstate[0, op]+')';
  end;
  
  i := i+1;
end;
self.STEX_Str := strm;
self.main_Str := m_str;
endf;
